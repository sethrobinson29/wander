@using Wander.Client.Models
@using MudBlazor

<MudDialog>
    <DialogContent>
        <div style="margin-bottom:12px;">
            <MudButton Variant="Variant.Outlined" Style="color:#948aa8; border-color:#352d47;"
                       OnClick="() => MudDialog.Close(DialogResult.Ok<Guid?>(null))">
                Reset to auto (commander art)
            </MudButton>
        </div>
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(146px,1fr)); gap:8px;">
            @foreach (var card in Cards.DistinctBy(c => c.CardId))
            {
                var c = card;
                <div @onclick="() => MudDialog.Close(DialogResult.Ok<Guid?>(c.ImagePrintingId))"
                     style="cursor:pointer; border-radius:6px; overflow:hidden;
                            border:2px solid @(c.ImagePrintingId == _currentPrintingId ? "#c4a35f" : "transparent");">
                    <img src="@(c.ImageUriArtCrop ?? c.ImageUriNormal)" alt="@c.CardName"
                         style="width:100%; display:block;" />
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<DeckCardDetail> Cards { get; set; } = [];
    [Parameter] public Guid? CurrentPrintingId { get; set; }

    Guid? _currentPrintingId;

    protected override void OnParametersSet() => _currentPrintingId = CurrentPrintingId;
}
