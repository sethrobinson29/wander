@inject WanderApiClient Api
@inject ISnackbar Snackbar

<MudDialog Style="min-width:480px;">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif;">New Deck</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Name" Variant="Variant.Outlined"
                      FullWidth="true" Class="mb-3"
                      Error="@(_submitted && _nameError != null)"
                      ErrorText="@_nameError" />
        <MudTextField @bind-Value="_description" Label="Description (optional)"
                      Variant="Variant.Outlined" FullWidth="true" Class="mb-3"
                      MaxLength="1000" />
        <MudSelect T="Format" Value="_format" Label="Format" Variant="Variant.Outlined"
                   FullWidth="true" Class="mb-3" ValueChanged="OnFormatChanged">
            @foreach (Format f in Enum.GetValues<Format>())
            {
                <MudSelectItem Value="@f">@f.ToString()</MudSelectItem>
            }
        </MudSelect>
        <MudSelect @bind-Value="_visibility" Label="Visibility" Variant="Variant.Outlined"
                   FullWidth="true" Class="mb-3">
            <MudSelectItem Value="Visibility.Public">Public</MudSelectItem>
            <MudSelectItem Value="Visibility.Private">Private</MudSelectItem>
            <MudSelectItem Value="Visibility.Unlisted">Unlisted</MudSelectItem>
        </MudSelect>

        @if (_format == Format.Commander)
        {
            <MudDivider Class="mb-3" />
            <MudText Typo="Typo.body2" Class="mb-2" Style="color:#9e94c8;">
                Commander (optional — can be set later in the deck builder)
            </MudText>

            @if (_selectedCommander != null)
            {
                <div class="d-flex align-center gap-2 mb-2 pa-2"
                     style="background:#1c1228; border:1px solid #c9a84c44; border-radius:4px;">
                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small"
                             Style="color:#c9a84c;" />
                    <MudText Typo="Typo.body2" Class="flex-grow-1">@_selectedCommander.Name</MudText>
                    <ManaCost Cost="@_selectedCommander.ManaCost" />
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   OnClick="() => _selectedCommander = null" />
                </div>
            }
            else
            {
                <div style="position:relative;">
                    <MudTextField T="string" Value="_commanderSearch" ValueChanged="OnCommanderSearchInput"
                                  Label="Search for a commander..."
                                  Variant="Variant.Outlined" FullWidth="true"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="300" />

                    @if (_commanderResults.Count > 0)
                    {
                        <MudList T="CardSearchResult"
                                 Style="position:absolute; top:100%; left:0; right:0; z-index:9999;
                                        background:#1c1228; border:1px solid #3d2d5e; border-radius:4px;
                                        max-height:200px; overflow-y:auto;">
                            @foreach (var card in _commanderResults)
                            {
                                <MudListItem T="CardSearchResult" OnClick="() => SelectCommander(card)"
                                             Style="border-bottom:1px solid #2a1d40; cursor:pointer;">
                                    <div class="d-flex justify-space-between align-center">
                                        <MudText Typo="Typo.body2">@card.Name</MudText>
                                        <ManaCost Cost="@card.ManaCost" />
                                    </div>
                                    <MudText Typo="Typo.caption" Style="color:#9e94c8;">@card.TypeLine</MudText>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </div>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Create"
                   Disabled="_loading">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    string _name = "", _description = "";
    Format _format = Format.Commander;
    Visibility _visibility = Visibility.Private;
    string _commanderSearch = "";
    List<CardSearchResult> _commanderResults = [];
    CardSearchResult? _selectedCommander;
    bool _loading, _submitted;
    string? _nameError;

    void Cancel() => MudDialog.Cancel();

    void OnFormatChanged(Format f)
    {
        _format = f;
        _selectedCommander = null;
        _commanderResults = [];
        _commanderSearch = "";
    }

    async Task OnCommanderSearchInput(string q)
    {
        _commanderSearch = q;
        if (q.Length < 2) { _commanderResults = []; return; }
        var results = await Api.SearchCardsAsync(q);
        // Only show Legendary cards as valid commander candidates
        _commanderResults = results
            .Where(c => c.TypeLine.Contains("Legendary", StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    void SelectCommander(CardSearchResult card)
    {
        _selectedCommander = card;
        _commanderResults = [];
        _commanderSearch = "";
    }

    async Task Create()
    {
        _submitted = true;
        _nameError = InputValidator.Validate(_name.Trim(), TextFieldType.Generic)
                     ?? (_name.Trim().Length > 200 ? "Name must be at most 200 characters." : null);
        if (_nameError != null) return;
        _loading = true;

        var response = await Api.CreateDeckAsync(
            new CreateDeckRequest(_name, _description, _format, _visibility));
        if (!response.IsSuccessStatusCode)
        {
            Snackbar.Add("Failed to create deck.", Severity.Error);
            _loading = false;
            return;
        }

        var created = await response.Content.ReadFromJsonAsync<DeckSummary>();

        if (_selectedCommander != null && created != null)
        {
            await Api.SetCardsAsync(created.Id,
                [new DeckCardRequest(_selectedCommander.Id, _selectedCommander.DefaultPrintingId, 1, true, false)]);
        }

        MudDialog.Close(DialogResult.Ok(created));
    }
}