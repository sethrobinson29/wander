@using Wander.Client.Models
@using Microsoft.JSInterop
@using System.Globalization
@inject WanderApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog MaxWidth="MaxWidth.Large" FullWidth="true">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif; color:#c9a84c;">
            Set Deck Image — @Card.CardName
        </MudText>
    </TitleContent>
    <DialogContent>
        <div style="user-select:none;">

            <!-- ── Image editor ─────────────────────────────────── -->
            <div style="position:relative;"
                 @ref="_containerRef"
                 @onmousemove="OnMouseMove"
                 @onmouseup="OnMouseUp"
                 @onmouseleave="OnMouseUp">

                <img src="@Card.ImageUriArtCrop"
                     style="width:100%; display:block; pointer-events:none;"
                     alt="@Card.CardName" />

                <!-- Dimmed masks outside crop box -->
                <div style="position:absolute; left:0; top:0; width:@Pct(_cropLeft)%; height:100%; background:rgba(0,0,0,0.5); pointer-events:none;" />
                <div style="position:absolute; left:@Pct(_cropLeft + _cropWidth)%; top:0; width:@Pct(1 - _cropLeft - _cropWidth)%; height:100%; background:rgba(0,0,0,0.5); pointer-events:none;" />
                <div style="position:absolute; left:@Pct(_cropLeft)%; top:0; width:@Pct(_cropWidth)%; height:@Pct(_cropTop)%; background:rgba(0,0,0,0.5); pointer-events:none;" />
                <div style="position:absolute; left:@Pct(_cropLeft)%; top:@Pct(_cropTop + _cropHeight)%; width:@Pct(_cropWidth)%; height:@Pct(1 - _cropTop - _cropHeight)%; background:rgba(0,0,0,0.5); pointer-events:none;" />

                <!-- Crop box (fixed aspect ratio — drag to reposition) -->
                <div style="position:absolute;
                            left:@Pct(_cropLeft)%; top:@Pct(_cropTop)%;
                            width:@Pct(_cropWidth)%; height:@Pct(_cropHeight)%;
                            border:2px solid #c9a84c; box-sizing:border-box; cursor:move;"
                     @onmousedown="StartDrag"
                     @onmousedown:stopPropagation>
                </div>
            </div>

            <!-- ── Banner preview ─────────────────────────────── -->
            <MudText Typo="Typo.caption" Style="color:#9e94c8; margin-top:12px; display:block;">
                Banner Preview · Drag to reposition
            </MudText>
            <div style="width:100%; height:100px; border-radius:4px; overflow:hidden;
                        border:1px solid #3d2d5e; margin-top:4px; background-repeat:no-repeat; @PreviewBg" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DeckCardDetail Card { get; set; } = null!;
    [Parameter] public Guid DeckId { get; set; }
    [Parameter] public double BannerWidth { get; set; }
    [Parameter] public double BannerHeight { get; set; }

    // Crop state — 0..1 fractions of the source image; aspect ratio locked to banner
    double _cropLeft, _cropTop, _cropWidth, _cropHeight;

    // Drag state
    bool _isDragging;
    double _dragStartX, _dragStartY;
    double _snapLeft, _snapTop;
    BoundingRect? _containerRect;
    ElementReference _containerRef;

    record BoundingRect(double Left, double Top, double Width, double Height);

    static string Pct(double v) =>
        (v * 100.0).ToString("F4", CultureInfo.InvariantCulture);

    string PreviewBg
    {
        get
        {
            var safeW = Math.Max(_cropWidth, 0.001);
            var safeH = Math.Max(_cropHeight, 0.001);
            var posX = Pct(_cropLeft / Math.Max(1.0 - safeW, 0.001));
            var posY = Pct(_cropTop / Math.Max(1.0 - safeH, 0.001));
            return $"background-image:url('{Card.ImageUriArtCrop}');" +
                   $"background-size:{Pct(1.0 / safeW)}% auto;" +
                   $"background-position:{posX}% {posY}%;";
        }
    }

    protected override void OnInitialized()
    {
        const double artCropAspect = 626.0 / 457.0; // Scryfall art_crop standard dimensions
        var bannerAspect = BannerWidth > 0 && BannerHeight > 0
            ? BannerWidth / BannerHeight
            : 5.5;
        _cropWidth = 0.85;
        _cropHeight = Math.Min(_cropWidth * artCropAspect / bannerAspect, 0.95);
        _cropLeft = (1.0 - _cropWidth) / 2.0;
        _cropTop = Math.Clamp((1.0 - _cropHeight) / 2.0, 0, 1.0 - _cropHeight);
    }

    async Task StartDrag(MouseEventArgs e)
    {
        _containerRect = await JS.InvokeAsync<BoundingRect>("getElementRect", _containerRef);
        _isDragging = true;
        _dragStartX = (e.ClientX - _containerRect.Left) / _containerRect.Width;
        _dragStartY = (e.ClientY - _containerRect.Top) / _containerRect.Height;
        _snapLeft = _cropLeft;
        _snapTop = _cropTop;
    }

    void OnMouseMove(MouseEventArgs e)
    {
        if (!_isDragging || _containerRect == null) return;

        var x = (e.ClientX - _containerRect.Left) / _containerRect.Width;
        var y = (e.ClientY - _containerRect.Top) / _containerRect.Height;
        _cropLeft = Math.Clamp(_snapLeft + (x - _dragStartX), 0, 1.0 - _cropWidth);
        _cropTop  = Math.Clamp(_snapTop  + (y - _dragStartY), 0, 1.0 - _cropHeight);
    }

    void OnMouseUp(MouseEventArgs _) => _isDragging = false;

    async Task Save()
    {
        var response = await Api.SetDeckCoverAsync(
            DeckId, Card.ImagePrintingId,
            _cropLeft, _cropTop, _cropWidth, _cropHeight);

        if (response.IsSuccessStatusCode)
            MudDialog.Close(DialogResult.Ok(true));
        else
            Snackbar.Add("Failed to save deck image.", Severity.Error);
    }
}
