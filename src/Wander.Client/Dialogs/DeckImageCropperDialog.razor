@using Wander.Client.Models
@using Microsoft.JSInterop
@inject WanderApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog MaxWidth="MaxWidth.Large" FullWidth="true">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif; color:#c9a84c;">
            Set Deck Image — @Card.CardName
        </MudText>
    </TitleContent>
    <DialogContent>
        <div class="d-flex gap-4" style="user-select:none;">

            <!-- ── Image editor ─────────────────────────────────── -->
            <div style="flex:1; position:relative;"
                 @ref="_containerRef"
                 @onmousemove="OnMouseMove"
                 @onmouseup="OnMouseUp"
                 @onmouseleave="OnMouseUp">

                <img src="@Card.ImageUriArtCrop"
                     style="width:100%; display:block; pointer-events:none;"
                     alt="@Card.CardName" />

                <!-- Dimmed masks outside crop box -->
                <div style="position:absolute; left:0; top:0; width:@Pct(_cropLeft)%; height:100%; background:rgba(0,0,0,0.5); pointer-events:none;" />
                <div style="position:absolute; left:@Pct(_cropLeft + _cropWidth)%; top:0; width:@Pct(1 - _cropLeft - _cropWidth)%; height:100%; background:rgba(0,0,0,0.5); pointer-events:none;" />
                <div style="position:absolute; left:@Pct(_cropLeft)%; top:0; width:@Pct(_cropWidth)%; height:@Pct(_cropTop)%; background:rgba(0,0,0,0.5); pointer-events:none;" />
                <div style="position:absolute; left:@Pct(_cropLeft)%; top:@Pct(_cropTop + _cropHeight)%; width:@Pct(_cropWidth)%; height:@Pct(1 - _cropTop - _cropHeight)%; background:rgba(0,0,0,0.5); pointer-events:none;" />

                <!-- Crop box -->
                <div style="position:absolute;
                    left:@Pct(_cropLeft)%; top:@Pct(_cropTop)%;
                    width:@Pct(_cropWidth)%; height:@Pct(_cropHeight)%;
                    border:2px solid #c9a84c; box-sizing:border-box; cursor:move;"
                     @onmousedown="e => StartDrag(e, DragMode.Move)"
                     @onmousedown:stopPropagation>

                    <!-- NW handle -->
                    <div style="position:absolute; left:-5px; top:-5px; width:10px; height:10px; background:#c9a84c; cursor:nw-resize;"
                         @onmousedown="e => StartDrag(e, DragMode.ResizeNW)"
                         @onmousedown:stopPropagation />
                    <!-- NE handle -->
                    <div style="position:absolute; right:-5px; top:-5px; width:10px; height:10px; background:#c9a84c; cursor:ne-resize;"
                         @onmousedown="e => StartDrag(e, DragMode.ResizeNE)"
                         @onmousedown:stopPropagation />
                    <!-- SW handle -->
                    <div style="position:absolute; left:-5px; bottom:-5px; width:10px; height:10px; background:#c9a84c; cursor:sw-resize;"
                         @onmousedown="e => StartDrag(e, DragMode.ResizeSW)"
                         @onmousedown:stopPropagation />
                    <!-- SE handle -->
                    <div style="position:absolute; right:-5px; bottom:-5px; width:10px; height:10px; background:#c9a84c; cursor:se-resize;"
                         @onmousedown="e => StartDrag(e, DragMode.ResizeSE)"
                         @onmousedown:stopPropagation />
                </div>
            </div>

            <!-- ── Preview ───────────────────────────────────────── -->
            <div style="width:280px; flex-shrink:0;">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Preview</MudText>
                <div style="width:100%; height:140px; border-radius:8px; overflow:hidden;
                    border:1px solid #3d2d5e; position:relative; background:#1c1228;">
                    <img src="@Card.ImageUriArtCrop"
                         style="position:absolute;
                    width:@Pct(1.0 / _cropWidth)%;
                    left:@Pct(-(_cropLeft / _cropWidth))%;
                    top:@Pct(-(_cropTop / _cropHeight))%;"
                         alt="preview" />
                </div>
                <MudText Typo="Typo.caption" Style="color:#9e94c8; margin-top:4px; display:block;">
                    Drag corners to resize · Drag box to move
                </MudText>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public DeckCardDetail Card { get; set; } = null!;
    [Parameter] public Guid DeckId { get; set; }

    // Crop state — all values are 0..1 fractions of the source image
    double _cropLeft = 0.05, _cropTop = 0.05, _cropWidth = 0.9, _cropHeight = 0.9;

    // Drag state
    bool _isDragging;
    DragMode _dragMode;
    double _dragStartX, _dragStartY;
    double _snapLeft, _snapTop, _snapWidth, _snapHeight;
    BoundingRect? _containerRect;
    ElementReference _containerRef;

    enum DragMode { Move, ResizeNW, ResizeNE, ResizeSW, ResizeSE }

    record BoundingRect(double Left, double Top, double Width, double Height);

    static string Pct(double v) =>
        (v * 100.0).ToString("F4", System.Globalization.CultureInfo.InvariantCulture);

    async Task StartDrag(MouseEventArgs e, DragMode mode)
    {
        // Fetch container bounds once per drag session — avoids JS call on every mouse move
        _containerRect = await JS.InvokeAsync<BoundingRect>("getElementRect", _containerRef);
        _isDragging = true;
        _dragMode = mode;
        _dragStartX = (e.ClientX - _containerRect.Left) / _containerRect.Width;
        _dragStartY = (e.ClientY - _containerRect.Top) / _containerRect.Height;
        _snapLeft = _cropLeft;
        _snapTop = _cropTop;
        _snapWidth = _cropWidth;
        _snapHeight = _cropHeight;
    }

    void OnMouseMove(MouseEventArgs e)
    {
        if (!_isDragging || _containerRect == null) return;

        var x = (e.ClientX - _containerRect.Left) / _containerRect.Width;
        var y = (e.ClientY - _containerRect.Top) / _containerRect.Height;
        var dx = x - _dragStartX;
        var dy = y - _dragStartY;

        const double MinSize = 0.05;

        switch (_dragMode)
        {
            case DragMode.Move:
                _cropLeft = Math.Clamp(_snapLeft + dx, 0, 1 - _cropWidth);
                _cropTop = Math.Clamp(_snapTop + dy, 0, 1 - _cropHeight);
                break;

            case DragMode.ResizeSE:
                _cropWidth = Math.Clamp(_snapWidth + dx, MinSize, 1 - _cropLeft);
                _cropHeight = Math.Clamp(_snapHeight + dy, MinSize, 1 - _cropTop);
                break;

            case DragMode.ResizeNW:
                {
                    var newL = Math.Clamp(_snapLeft + dx, 0, _snapLeft + _snapWidth - MinSize);
                    var newT = Math.Clamp(_snapTop + dy, 0, _snapTop + _snapHeight - MinSize);
                    _cropWidth = _snapLeft + _snapWidth - newL;
                    _cropHeight = _snapTop + _snapHeight - newT;
                    _cropLeft = newL;
                    _cropTop = newT;
                    break;
                }

            case DragMode.ResizeNE:
                {
                    var newT = Math.Clamp(_snapTop + dy, 0, _snapTop + _snapHeight - MinSize);
                    _cropWidth = Math.Clamp(_snapWidth + dx, MinSize, 1 - _cropLeft);
                    _cropHeight = _snapTop + _snapHeight - newT;
                    _cropTop = newT;
                    break;
                }

            case DragMode.ResizeSW:
                {
                    var newL = Math.Clamp(_snapLeft + dx, 0, _snapLeft + _snapWidth - MinSize);
                    _cropWidth = _snapLeft + _snapWidth - newL;
                    _cropHeight = Math.Clamp(_snapHeight + dy, MinSize, 1 - _cropTop);
                    _cropLeft = newL;
                    break;
                }
        }
    }

    void OnMouseUp(MouseEventArgs _) => _isDragging = false;

    async Task Save()
    {
        var response = await Api.SetDeckCoverAsync(
            DeckId, Card.ImagePrintingId,
            _cropLeft, _cropTop, _cropWidth, _cropHeight);

        if (response.IsSuccessStatusCode)
            MudDialog.Close(DialogResult.Ok(true));
        else
            Snackbar.Add("Failed to save deck image.", Severity.Error);
    }
}