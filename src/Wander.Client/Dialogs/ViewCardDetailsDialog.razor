@using Wander.Client.Models

<MudDialog Style="min-width:560px; max-height:90vh; overflow:hidden;">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif; color:#c4a35f;">Card Details</MudText>
            @if (IsmdFc)
            {
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.Autorenew"
                           Style="color:#948aa8; border-color:#352d47;"
                           OnClick="() => _showingBack = !_showingBack">
                    @(_showingBack ? "Front Face" : "Flip Card")
                </MudButton>
            }
        </div>
    </TitleContent>
    <DialogContent>
        <div style="overflow-y:auto; max-height:calc(90vh - 130px);">
            <!-- Top: image + card info -->
            <div class="d-flex gap-4 mb-4">
                @if (ActiveImageUri != null)
                {
                    <img src="@ActiveImageUri" style="width:220px; border-radius:8px; flex-shrink:0; align-self:flex-start;" alt="@ActiveName" />
                }
                <div class="flex-grow-1" style="min-width:200px;">
                    <div class="d-flex align-center gap-2 flex-wrap mb-1">
                        <MudText Typo="Typo.h5" Style="font-family:'Cinzel',serif; color:#c4a35f;">@ActiveName</MudText>
                        <ManaCost Cost="@ActiveManaCost" />
                    </div>
                    <MudText Typo="Typo.caption" Style="color:#948aa8; display:block; margin-bottom:12px;">@ActiveTypeLine</MudText>
                    @if (!string.IsNullOrWhiteSpace(ActiveOracleText))
                    {
                        <MudText Style="white-space:pre-wrap; margin-bottom:8px; line-height:1.5;">@ActiveOracleText</MudText>
                    }
                    @if (!_showingBack && !string.IsNullOrWhiteSpace(FlavorText))
                    {
                        <MudDivider Style="margin:8px 0; border-color:#352d47;" />
                        <MudText Style="font-style:italic; color:#948aa8; white-space:pre-wrap; line-height:1.5;">@FlavorText</MudText>
                    }
                </div>
            </div>

            <!-- Bottom: legalities (same for both faces) -->
            @if (Legalities.Count > 0)
            {
                <MudDivider Style="margin-bottom:12px; border-color:#352d47;" />
                <MudText Typo="Typo.subtitle2" Style="margin-bottom:8px;">Format Legality</MudText>
                <div class="d-flex flex-wrap gap-1">
                    @foreach (var (format, status) in Legalities.OrderBy(l => l.Key))
                    {
                        var (bg, fg) = status switch
                        {
                            "legal"      => ("#4caf5022", "#4caf50"),
                            "restricted" => ("#ff980022", "#ff9800"),
                            "banned"     => ("#f4433622", "#f44336"),
                            _            => ("#ffffff11", "#666")
                        };
                        <div style="background:@bg; color:@fg; border:1px solid @fg; border-radius:4px; padding:2px 8px; font-size:0.7rem; white-space:nowrap;">
                            @FormatName(format): @status
                        </div>
                    }
                </div>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Close()">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public DeckCardDetail? Card { get; set; }
    [Parameter] public CardSearchResult? SearchCard { get; set; }

    bool _showingBack;

    // Raw source properties
    string FullName      => Card?.CardName ?? SearchCard?.Name ?? "";
    string? FrontManaCost => Card?.ManaCost ?? SearchCard?.ManaCost;
    string FullTypeLine  => Card?.TypeLine ?? SearchCard?.TypeLine ?? "";
    string? FrontOracleText => Card?.OracleText ?? SearchCard?.OracleText;
    string? FlavorText   => Card?.FlavorText;
    string? FrontImageUri => Card?.ImageUriNormal ?? SearchCard?.ImageUriNormal;

    string? BackFaceManaCost  => Card?.BackFaceManaCost  ?? SearchCard?.BackFaceManaCost;
    string? BackFaceTypeLine  => Card?.BackFaceTypeLine  ?? SearchCard?.BackFaceTypeLine;
    string? BackFaceOracleText => Card?.BackFaceOracleText ?? SearchCard?.BackFaceOracleText;
    string? BackImageUri      => Card?.BackImageUriNormal ?? SearchCard?.BackImageUriNormal;

    bool IsmdFc => FullName.Contains(" // ");

    // Face-aware display properties
    string ActiveName => _showingBack
        ? (FullName.Contains(" // ") ? FullName[(FullName.IndexOf(" // ") + 4)..] : FullName)
        : (FullName.Contains(" // ") ? FullName[..FullName.IndexOf(" // ")] : FullName);

    string? ActiveManaCost   => _showingBack ? BackFaceManaCost   : FrontManaCost;
    string  ActiveTypeLine   => _showingBack ? (BackFaceTypeLine ?? FullTypeLine) : FullTypeLine.Split(" // ")[0];
    string? ActiveOracleText => _showingBack ? BackFaceOracleText : FrontOracleText;
    string? ActiveImageUri   => _showingBack ? BackImageUri       : FrontImageUri;

    Dictionary<string, string> Legalities =>
        Card?.Legalities ?? SearchCard?.Legalities ?? new Dictionary<string, string>();

    static string FormatName(string key) =>
        key switch
        {
            "standard"  => "Standard",
            "pioneer"   => "Pioneer",
            "modern"    => "Modern",
            "legacy"    => "Legacy",
            "vintage"   => "Vintage",
            "commander" => "Commander",
            "pauper"    => "Pauper",
            "explorer"  => "Explorer",
            "historic"  => "Historic",
            "timeless"  => "Timeless",
            _           => key
        };
}
