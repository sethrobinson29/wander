@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="0" Style="border-bottom: 1px solid #3d2d5e;">
        <MudButton Variant="Variant.Text" Href="/"
                   Style="font-family:'Cinzel',serif; color:#c9a84c; letter-spacing:0.08em; font-size:1.1rem; text-transform:none; padding:0 8px; margin-right:16px; min-width:unset;">
            WANDER
        </MudButton>
        <MudButton Variant="Variant.Text" Href="/"
                   Style="color:#e8e0ff; text-transform:none; min-width:unset;">Home</MudButton>
        <MudButton Variant="Variant.Text" Href="/browse"
                   Style="color:#e8e0ff; text-transform:none; min-width:unset;">Browse</MudButton>
        <MudButton Variant="Variant.Text" Href="/help"
                   Style="color:#e8e0ff; text-transform:none; min-width:unset;">Help</MudButton>
        <AuthorizeView>
            <Authorized>
                <span style="color:#9e94c8; margin:0 4px; user-select:none;">|</span>
                <MudButton Variant="Variant.Text" Href="/decks"
                           Style="color:#e8e0ff; text-transform:none; min-width:unset;">Your Collection</MudButton>
            </Authorized>
        </AuthorizeView>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                               Color="Color.Primary" Href="/decks" Style="margin-right:8px;" />
                <MudButton Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="Logout">Log Out</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                    Log In
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    [Inject] LocalStorage LocalStorage { get; set; } = null!;
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] NavigationManager Nav { get; set; } = null!;

    async Task Logout()
    {
        await LocalStorage.RemoveAsync("accessToken");
        await LocalStorage.RemoveAsync("refreshToken");
        ((JwtAuthStateProvider)AuthStateProvider).NotifyUserChanged();
        Nav.NavigateTo("/");
    }
}
