@inherits LayoutComponentBase

<MudLayout>
    <MudAppBar Elevation="0" Style="border-bottom: 1px solid #352d47; position:relative;">
        <MudButton Variant="Variant.Text" Href="/"
                   Style="font-family:'Cinzel',serif; color:#c4a35f; letter-spacing:0.08em; font-size:1.1rem; text-transform:none; padding:0 8px; margin-right:16px; min-width:unset;">
            WANDER
        </MudButton>
        <MudButton Variant="Variant.Text" Href="/"
                   Style="color:#ebe4d0; text-transform:none; min-width:unset;">Home</MudButton>
        <MudButton Variant="Variant.Text" Href="/browse"
                   Style="color:#ebe4d0; text-transform:none; min-width:unset;">Browse</MudButton>
        <MudButton Variant="Variant.Text" Href="/help"
                   Style="color:#ebe4d0; text-transform:none; min-width:unset;">Help</MudButton>
        <AuthorizeView Roles="Admin">
            <NotAuthorized Context="collectionCtx">
                <AuthorizeView Context="innerCtx">
                    <Authorized>
                        <span style="color:#948aa8; margin:0 4px; user-select:none;">|</span>
                        <MudButton Variant="Variant.Text" Href="/decks"
                                   Style="color:#ebe4d0; text-transform:none; min-width:unset;">Your Collection</MudButton>
                    </Authorized>
                </AuthorizeView>
            </NotAuthorized>
        </AuthorizeView>
        <div style="position:absolute; left:50%; top:50%; transform:translate(-50%,-50%);">
            <SearchBar />
        </div>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <NotificationBell />
                <MudIconButton Icon="@Icons.Material.Filled.AccountCircle"
                               Color="Color.Primary" Href="/settings" Style="margin-right:8px;" />
                <AuthorizeView Roles="Admin">
                    <Authorized Context="adminCtx">
                        <MudButton Variant="Variant.Text" Href="/admin"
                                   Style="color:#c4a35f; text-transform:none; min-width:unset; margin-right:8px;">Admin</MudButton>
                    </Authorized>
                </AuthorizeView>
                <MudButton Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="Logout">Log Out</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Href="/login" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                    Log In
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>

    <footer style="border-top:1px solid #352d47; padding:16px 24px; display:flex; align-items:center; justify-content:space-between;">
        <MudText Typo="Typo.caption" Style="color:#645a76;">Wander © 2025</MudText>
        <div class="d-flex align-center gap-2">
            <MudLink Href="https://sethrobinson29.com" Target="_blank"
                     Style="color:#645a76; font-size:0.75rem;">sethrobinson29.com</MudLink>
            <span style="color:#352d47;">|</span>
            <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit"
                           Href="https://github.com/sethrobinson29" Target="_blank"
                           Style="color:#645a76;" Size="Size.Small" />
        </div>
    </footer>
</MudLayout>

@code {
    [Inject] LocalStorage LocalStorage { get; set; } = null!;
    [Inject] AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] NavigationManager Nav { get; set; } = null!;

    async Task Logout()
    {
        await LocalStorage.RemoveAsync("accessToken");
        await LocalStorage.RemoveAsync("refreshToken");
        ((JwtAuthStateProvider)AuthStateProvider).NotifyUserChanged();
        Nav.NavigateTo("/");
    }
}
