@page "/admin/activity"
@attribute [Authorize(Roles = "Admin")]
@layout Layout.AdminLayout
@inject WanderApiClient Api
@inject NavigationManager Nav

<PageTitle>Activity Log — WanderAdmin</PageTitle>

<div style="display:flex; height:100%; overflow:hidden;">

    <AdminSidebar ActivePage="activity" />

    <!-- ── Main content ────────────────────────────────────────────────── -->
    <main style="flex:1; overflow-y:auto; padding:32px; display:flex; flex-direction:column; gap:16px;">

        <div>
            <MudText Typo="Typo.h5" Style="font-family:'Cinzel',serif;">Activity Log</MudText>
            @if (_data != null)
            {
                <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary); font-family:monospace;">
                    @_data.TotalCount total entries
                </MudText>
            }
        </div>

        <!-- Filters -->
        <div class="d-flex align-center gap-3 flex-wrap">
            <MudSelect T="string" Value="@_typeFilter" ValueChanged="OnTypeFilterChanged"
                       Label="Event type" Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="min-width:160px;" Dense="true">
                <MudSelectItem Value="@("")">All events</MudSelectItem>
                <MudSelectItem Value="@("user")">User events</MudSelectItem>
                <MudSelectItem Value="@("job")">Job events</MudSelectItem>
                <MudSelectItem Value="@("auth")">Auth events</MudSelectItem>
            </MudSelect>

            <MudSelect T="string" Value="@_severityFilter" ValueChanged="OnSeverityFilterChanged"
                       Label="Severity" Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="min-width:130px;" Dense="true">
                <MudSelectItem Value="@("")">All severities</MudSelectItem>
                <MudSelectItem Value="@("info")">Info</MudSelectItem>
                <MudSelectItem Value="@("warning")">Warning</MudSelectItem>
                <MudSelectItem Value="@("error")">Error</MudSelectItem>
            </MudSelect>
        </div>

        <!-- Table -->
        <MudPaper Elevation="0" Style="border:1px solid var(--mud-palette-lines-default); border-radius:8px; overflow:hidden; flex:1;">
            @if (_loading && _data == null)
            {
                <div style="padding:32px; text-align:center;">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </div>
            }
            else if (_error != null)
            {
                <div style="padding:32px; text-align:center;">
                    <MudText Style="color:var(--mud-palette-error);">@_error</MudText>
                    <MudButton Class="mt-3" OnClick="FetchAsync">Retry</MudButton>
                </div>
            }
            else
            {
                @if (_loading)
                {
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Style="height:2px;" />
                }
                <table style="width:100%; border-collapse:collapse;">
                    <thead>
                        <tr style="border-bottom:1px solid var(--mud-palette-lines-default); background:var(--mud-palette-surface);">
                            <th class="admin-th">Event</th>
                            <th class="admin-th">Severity</th>
                            <th class="admin-th">Actor</th>
                            <th class="admin-th">Target</th>
                            <th class="admin-th">When</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_data?.Entries.Count == 0)
                        {
                            <tr>
                                <td colspan="5" style="padding:32px; text-align:center; color:var(--mud-palette-text-secondary);">
                                    No log entries.
                                </td>
                            </tr>
                        }
                        @foreach (var entry in _data?.Entries ?? [])
                        {
                            <tr style="border-bottom:1px solid var(--mud-palette-lines-default);" class="admin-row">
                                <td style="padding:10px 12px; font-family:monospace; font-size:0.82rem;">
                                    @entry.EventType
                                    @if (entry.AffectedCount.HasValue)
                                    {
                                        <span style="margin-left:6px; color:var(--mud-palette-text-secondary);">
                                            × @entry.AffectedCount
                                        </span>
                                    }
                                </td>
                                <td style="padding:10px 12px;">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@SeverityColor(entry.Severity)"
                                             Variant="Variant.Filled">
                                        @entry.Severity
                                    </MudChip>
                                </td>
                                <td style="padding:10px 12px; font-size:0.82rem; color:var(--mud-palette-text-secondary);">
                                    @(entry.ActorUsername ?? (entry.ActorId != null ? entry.ActorId[..8] + "…" : "system"))
                                </td>
                                <td style="padding:10px 12px; font-family:monospace; font-size:0.82rem; color:var(--mud-palette-text-secondary);">
                                    @if (entry.TargetType == "user")
                                    {
                                        @(entry.TargetUsername ?? entry.TargetId ?? "—")
                                    }
                                    else
                                    {
                                        @(entry.TargetId ?? entry.TargetType ?? "—")
                                    }
                                </td>
                                <td style="padding:10px 12px; font-family:monospace; font-size:0.82rem; color:var(--mud-palette-text-secondary);">
                                    @entry.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </MudPaper>

        <!-- Pagination -->
        @if (_data != null && _data.TotalCount > 0)
        {
            <div class="d-flex align-center justify-space-between">
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                    Showing @((_data.Page - 1) * _data.PageSize + 1)–@Math.Min(_data.Page * _data.PageSize, _data.TotalCount) of @_data.TotalCount
                </MudText>
                <div class="d-flex align-center gap-2">
                    <MudText Typo="Typo.caption" Style="font-family:monospace;">
                        Page @_data.Page of @_data.TotalPages
                    </MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                                   Disabled="@(_data.Page <= 1 || _loading)" OnClick="PrevPage" />
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                                   Disabled="@(_data.Page >= _data.TotalPages || _loading)" OnClick="NextPage" />
                </div>
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">25 per page</MudText>
            </div>
        }
    </main>
</div>

<style>
    .admin-th {
        padding: 10px 12px;
        text-align: left;
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--mud-palette-text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .admin-row:hover { background: var(--mud-palette-action-hover) !important; }
</style>

@code {
    AuditLogListResponse? _data;
    bool _loading;
    string? _error;
    string _typeFilter = "";
    string _severityFilter = "";
    int _page = 1;

    protected override async Task OnInitializedAsync() => await FetchAsync();

    async Task FetchAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();
        try
        {
            _data = await Api.AdminGetActivityAsync(
                type: string.IsNullOrEmpty(_typeFilter) ? null : _typeFilter,
                severity: string.IsNullOrEmpty(_severityFilter) ? null : _severityFilter,
                page: _page);
        }
        catch
        {
            _error = "Failed to load activity log.";
        }
        _loading = false;
    }

    async Task OnTypeFilterChanged(string value) { _typeFilter = value; _page = 1; await FetchAsync(); }
    async Task OnSeverityFilterChanged(string value) { _severityFilter = value; _page = 1; await FetchAsync(); }
    async Task PrevPage() { _page--; await FetchAsync(); }
    async Task NextPage() { _page++; await FetchAsync(); }

    static Color SeverityColor(string severity) => severity switch
    {
        "warning" => Color.Warning,
        "error" => Color.Error,
        _ => Color.Default,
    };

}
