@page "/"
@inject WanderApiClient Api
@inject NavigationManager Nav

<MudText Typo="Typo.h4" Class="page-title">Browse Decks</MudText>

<div class="d-flex align-center gap-3 mb-4">
    <MudText Typo="Typo.body2" Style="color:#948aa8;">Filter by format:</MudText>
    <MudChip T="string" Variant="Variant.Outlined" Color="@(_format == null ? Color.Primary : Color.Default)"
             OnClick="() => SetFormat(null)">All</MudChip>
    @foreach (Format f in Enum.GetValues<Format>())
    {
        <MudChip T="string" Variant="Variant.Outlined"
                 Color="@(_format == f ? Color.Primary : Color.Default)"
                 OnClick="() => SetFormat(f)">@f.ToString()</MudChip>
    }
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_decks.Count == 0)
{
    <MudText Style="color:#948aa8;">No public decks found.</MudText>
}
else
{
    <MudGrid>
        @foreach (var deck in _decks)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Style="border:1px solid #352d47; cursor:pointer;" Class="deck-card"
                         @onclick='() => Nav.NavigateTo($"/decks/{deck.Id}")'>
                    <div style="height:120px;border-radius:4px 4px 0 0;@ColorIdentityHelper.BannerStyle(deck.ColorIdentity)"></div>
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif;">@deck.Name</MudText>
                        <div class="d-flex align-center gap-2 mt-1">
                            <FormatBadge Format="@deck.Format" />
                            <MudLink Href="@($"/users/{deck.OwnerUsername}")" Typo="Typo.caption" Style="color:#948aa8;"
                                     @onclick:stopPropagation="true">by @deck.OwnerUsername</MudLink>
                            <MudText Typo="Typo.caption" Style="color:#948aa8;">· @deck.CardCount cards</MudText>
                        </div>
                        @if (deck.Description != null)
                        {
                            <MudText Typo="Typo.body2" Class="mt-2" Style="color:#948aa8;">@deck.Description</MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    List<DeckSummary> _decks = [];
    bool _loading = true;
    Format? _format;

    protected override async Task OnInitializedAsync() => await LoadDecks();

    async Task SetFormat(Format? f)
    {
        _format = f;
        await LoadDecks();
    }

    async Task LoadDecks()
    {
        _loading = true;
        _decks = await Api.GetPublicDecksAsync(_format);
        _loading = false;
    }
}