    async Task OpenCoverPicker()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters<Dialogs.CoverPickerDialog>
        {
            { d => d.Cards, _localCards.Where(c => c.ImageUriArtCrop != null || c.ImageUriNormal != null).ToList() },
            { d => d.CurrentPrintingId, _localCards.FirstOrDefault(c => c.ImageUriArtCrop == _deck!.CoverImageUri)?.ImagePrintingId }
        };
        var dialog = await Dialogs.ShowAsync<Dialogs.CoverPickerDialog>("Choose Cover Image", parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            var card = result.Data is Guid printingId
                ? _localCards.FirstOrDefault(c => c.ImagePrintingId == printingId)
                : _localCards.FirstOrDefault(c => c.IsCommander);

            if (card != null)
                await OpenSetAsImage(card);
        }
    }

