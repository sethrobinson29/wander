    // ── Visibility ────────────────────────────────────────────────────────────

    static string VisibilityIcon(Visibility v) => v switch
    {
        Visibility.Public   => Icons.Material.Filled.Public,
        Visibility.Private  => Icons.Material.Filled.Lock,
        Visibility.Unlisted => Icons.Material.Filled.Link,
        _                   => Icons.Material.Filled.Visibility,
    };

    async Task ChangeVisibility(Visibility newVis)
    {
        if (_deck == null || newVis == _deck.Visibility) return;
        var response = await Api.UpdateDeckAsync(Id, new UpdateDeckRequest(
            _deck.Name, _deck.Description, _deck.Primer, _deck.Format, newVis));
        if (response.IsSuccessStatusCode)
        {
            _deck = _deck with { Visibility = newVis };
            Snackbar.Add($"Visibility set to {newVis}.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to update visibility.", Severity.Error);
        }
    }

    static List<string> FilterDeckErrors(List<string> errors) =>
        errors.Where(e => !e.Contains("must have exactly", StringComparison.OrdinalIgnoreCase)).ToList();

    // ── Helpers ───────────────────────────────────────────────────────────────
    static string GetTypeGroup(string typeLine)
    {
        // MDFCs store both faces' types as "Front Type // Back Type" — group by front face only
        var frontTypeLine = typeLine.Contains(" // ", StringComparison.Ordinal)
            ? typeLine[..typeLine.IndexOf(" // ", StringComparison.Ordinal)]
            : typeLine;

        return new[] { "Creature", "Instant", "Sorcery", "Enchantment", "Artifact", "Planeswalker", "Battle", "Land" }
            .FirstOrDefault(t => frontTypeLine.Contains(t, StringComparison.OrdinalIgnoreCase)) ?? "Other";
    }

    static int TypeGroupOrder(string group) =>
        group switch
        {
            "Creature"     => 0, "Instant"      => 1, "Sorcery"    => 2, "Enchantment" => 3,
            "Artifact"     => 4, "Planeswalker" => 5, "Battle"     => 6, "Land"        => 7,
            _              => 8,
        };

    string GetGroupKey(DeckCardDetail c) => _groupBy switch
    {
        DeckGroupBy.Type          => GetTypeGroup(c.TypeLine),
        DeckGroupBy.ManaValue     => c.Cmc >= 7 ? "7+" : ((int)c.Cmc).ToString(),
        DeckGroupBy.Color         => c.TypeLine.Contains("Land", StringComparison.OrdinalIgnoreCase)
                                         ? "Land"
                                         : GetColorGroup(c.ColorIdentity),
        DeckGroupBy.ColorIdentity => GetColorIdentityGroup(c.ColorIdentity),
        DeckGroupBy.None          => "All Cards",
        _                         => GetTypeGroup(c.TypeLine)
    };

    int GetGroupOrder(string key) => _groupBy switch
    {
        DeckGroupBy.Type          => TypeGroupOrder(key),
        DeckGroupBy.ManaValue     => key == "7+" ? 7 : int.TryParse(key, out var n) ? n : 99,
        DeckGroupBy.Color         => ColorGroupOrder(key),
        DeckGroupBy.ColorIdentity => ColorGroupOrder(key),
        DeckGroupBy.None          => 0,
        _                         => 0
    };

    static string GetColorGroup(List<string> identity) => identity.Count switch
    {
        0 => "Colorless",
        1 => identity[0] switch { "W" => "White", "U" => "Blue", "B" => "Black", "R" => "Red", "G" => "Green", _ => "Colorless" },
        _ => "Multicolor"
    };

    static string GetColorIdentityGroup(List<string> identity) => identity.Count switch
    {
        0 => "Colorless",
        1 => identity[0],
        _ => string.Join("", identity.OrderBy(c => "WUBRG".IndexOf(c)))
    };

    static readonly Dictionary<string, int> _colorOrder = new()
    {
        ["White"] = 0, ["W"] = 0,
        ["Blue"]  = 1, ["U"] = 1,
        ["Black"] = 2, ["B"] = 2,
        ["Red"]   = 3, ["R"] = 3,
        ["Green"] = 4, ["G"] = 4,
    };

    static int ColorGroupOrder(string key) =>
        key == "Colorless" ? 99 :
        key == "Land"      ? 90 :
        _colorOrder.TryGetValue(key, out var o) ? o : 50;

    IEnumerable<DeckCardDetail> SortCards(IEnumerable<DeckCardDetail> cards) => _sortBy switch
    {
        DeckSortBy.Name      => cards.OrderBy(c => c.CardName),
        DeckSortBy.ManaValue => cards.OrderBy(c => c.Cmc).ThenBy(c => c.CardName),
        _                    => cards.OrderBy(c => c.Cmc).ThenBy(c => c.CardName)
    };
}
