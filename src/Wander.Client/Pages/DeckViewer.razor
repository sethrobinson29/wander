    // ── Card search ───────────────────────────────────────────────────────────

    async Task OnSearchInput(string q)
    {
        _searchQuery = q.Replace("\r", "").Replace("\n", "");
        if (_searchQuery.Length < 2) { _searchResults = []; return; }
        _searchResults = await Api.SearchCardsAsync(_searchQuery);
    }

    void OpenSearchCtx(MouseEventArgs e, CardSearchResult card)
    {
        _ctxCard = card;
        _ctxX = $"{e.ClientX}px";
        _ctxY = $"{e.ClientY}px";
        _ctxOpen = true;
    }

    void CloseSearchCtx() => _ctxOpen = false;

    async Task OnSearchFocusOut()
    {
        // Delay lets click on result or context menu item register before list clears.
        await Task.Delay(300);
        _searchResults = [];
        _searchQuery = "";
    }

    // ── Card mutations ────────────────────────────────────────────────────────

    void AddCard(CardSearchResult card)
    {
        _searchResults = [];
        _searchQuery = "";
        var existing = _localCards.FirstOrDefault(c => c.CardId == card.Id && !c.IsCommander);
        if (existing != null)
            _localCards = _localCards.Select(c => c == existing
                ? c with { Quantity = c.Quantity + 1 } : c).ToList();
        else
            _localCards.Add(new DeckCardDetail(Guid.NewGuid(), card.Id, card.DefaultPrintingId, card.Name, card.ManaCost,
                card.Cmc, card.TypeLine, card.OracleText, null, card.Legalities, card.ColorIdentity, card.ImageUriNormal,
                card.ImageUriSmall, card.ImageUriArtCrop, card.DefaultPrintingId, 1, false, false, []));
    }

    void AddToSideboard(CardSearchResult card)
    {
        _searchResults = [];
        _searchQuery = "";
        var existing = _localCards.FirstOrDefault(c => c.CardId == card.Id && c.IsSideboard);
        if (existing != null)
            _localCards = _localCards.Select(c => c == existing
                ? c with { Quantity = c.Quantity + 1 } : c).ToList();
        else
            _localCards.Add(new DeckCardDetail(Guid.NewGuid(), card.Id, card.DefaultPrintingId, card.Name, card.ManaCost,
                card.Cmc, card.TypeLine, card.OracleText, null, card.Legalities, card.ColorIdentity, card.ImageUriNormal,
                card.ImageUriSmall, card.ImageUriArtCrop, card.DefaultPrintingId, 1, false, true, []));
    }

    void AddAsCommander(CardSearchResult card)
    {
        _searchResults = [];
        _searchQuery = "";
        if (_localCards.Any(c => c.CardId == card.Id && c.IsCommander)) return;
        _localCards.Add(new DeckCardDetail(Guid.NewGuid(), card.Id, card.DefaultPrintingId, card.Name, card.ManaCost,
            card.Cmc, card.TypeLine, card.OracleText, null, card.Legalities, card.ColorIdentity, card.ImageUriNormal,
            card.ImageUriSmall, card.ImageUriArtCrop, card.DefaultPrintingId, 1, true, false, []));
    }

    void MakeCommander(DeckCardDetail card)
    {
        if (_localCards.Any(c => c.CardId == card.CardId && c.IsCommander)) return;
        var commanders = _localCards.Where(c => c.IsCommander).ToList();
        _localCards.Remove(card);
        if (commanders.Count == 1 && HasPartner(commanders[0]) && HasPartner(card))
        {
            _localCards.Add(card with { Id = Guid.NewGuid(), IsCommander = true, Quantity = 1 });
            return;
        }
        _localCards = _localCards.Where(c => !c.IsCommander).ToList();
        _localCards.Add(card with { Id = Guid.NewGuid(), IsCommander = true, Quantity = 1 });
    }

    async Task AddMore(DeckCardDetail card)
    {
        var input = await JS.InvokeAsync<string?>("prompt", "How many copies to add?", "1");
        if (int.TryParse(input, out var count) && count > 0)
            _localCards = _localCards.Select(c => c == card ? c with { Quantity = c.Quantity + count } : c).ToList();
    }

    bool IsOutsideColorIdentity(DeckCardDetail card)
    {
        var commanders = _localCards.Where(c => c.IsCommander).ToList();
        if (commanders.Count == 0) return false;
        var commanderColors = commanders.SelectMany(c => c.ColorIdentity).ToHashSet();
        return card.ColorIdentity.Any(color => !commanderColors.Contains(color));
    }

    static bool IsLegalCommander(DeckCardDetail card) =>
        card.TypeLine.Contains("Legendary", StringComparison.OrdinalIgnoreCase) ||
        card.OracleText?.Contains("can be your commander", StringComparison.OrdinalIgnoreCase) == true;

    static bool HasPartner(DeckCardDetail card) =>
        card.OracleText != null &&
        (card.OracleText.Contains("Partner with", StringComparison.OrdinalIgnoreCase) ||
         card.OracleText.Contains("\nPartner\n", StringComparison.OrdinalIgnoreCase) ||
         card.OracleText.EndsWith("\nPartner", StringComparison.OrdinalIgnoreCase) ||
         card.OracleText.EndsWith("Partner", StringComparison.OrdinalIgnoreCase));

    void MoveToSideboard(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { IsSideboard = true } : c).ToList();

    void MoveToMain(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { IsSideboard = false } : c).ToList();

    void DemoteCommander(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { IsCommander = false } : c).ToList();

    void IncrementCard(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { Quantity = c.Quantity + 1 } : c).ToList();

    void DecrementCard(DeckCardDetail card)
    {
        if (card.Quantity <= 1) RemoveCard(card);
        else _localCards = _localCards.Select(c => c == card ? c with { Quantity = c.Quantity - 1 } : c).ToList();
    }

    void RemoveCard(DeckCardDetail card) => _localCards.Remove(card);

    // ── Save ──────────────────────────────────────────────────────────────────

    async Task SaveCards()
    {
        _saving = true;
        var requests = _localCards.Select(c =>
            new DeckCardRequest(c.CardId, c.PrintingId, c.Quantity, c.IsCommander, c.IsSideboard)).ToList();
        var response = await Api.SetCardsAsync(Id, requests);
        if (!response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadFromJsonAsync<Dictionary<string, List<string>>>();
            _validationErrors = body?.GetValueOrDefault("errors") ?? ["Save failed."];
        }
        else
        {
            var saved = await response.Content.ReadFromJsonAsync<DeckDetail>();
            _validationErrors = FilterDeckErrors(saved?.DeckErrors ?? []);
            Snackbar.Add("Deck saved.", Severity.Success);
        }
        _saving = false;
    }

    async Task OpenBulkExport()
    {
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var parameters = new DialogParameters<Dialogs.BulkExportDialog>
        {
            { d => d.Decklist, BuildDecklist() }
        };
        await Dialogs.ShowAsync<Dialogs.BulkExportDialog>("Export Decklist", parameters, options);
    }

    string BuildDecklist()
    {
        var sb = new System.Text.StringBuilder();

        foreach (var card in _localCards.Where(c => c.IsCommander))
            sb.AppendLine($"{card.Quantity} {card.CardName} *CMDR*");

        foreach (var card in _localCards.Where(c => !c.IsCommander && !c.IsSideboard))
            sb.AppendLine($"{card.Quantity} {card.CardName}");

        var sideboard = _localCards.Where(c => c.IsSideboard).ToList();
        if (sideboard.Count > 0)
        {
            sb.AppendLine("SIDEBOARD:");
            foreach (var card in sideboard)
                sb.AppendLine($"{card.Quantity} {card.CardName}");
        }

        return sb.ToString().TrimEnd();
    }

    async Task OpenBulkImport()
    {
        var dialog = await Dialogs.ShowAsync<Dialogs.BulkImportDialog>("Bulk Import",
            new DialogParameters<Dialogs.BulkImportDialog> { { d => d.DeckId, Id } });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is DeckDetail updated)
        {
            _localCards = updated.Cards.ToList();
            _validationErrors = FilterDeckErrors(updated.DeckErrors);
        }
    }

