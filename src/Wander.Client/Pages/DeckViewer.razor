@page "/decks/{Id:guid}"
@inject WanderApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthState
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using MudBlazor.Charts

@if (_deck == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    return;
}

<!-- Header -->
<div class="d-flex justify-space-between align-center mb-4">
    <div>
        @if (_isOwner && _editingName)
        {
            <MudTextField @bind-Value="_pendingName" Variant="Variant.Text" AutoFocus="true"
                          Style="font-family:'Cinzel',serif; color:#c9a84c; font-size:1.5rem; font-weight:400;"
                          OnBlur="SaveName" />
        }
        else if (_isOwner)
        {
            <MudText Typo="Typo.h4" Style="font-family:'Cinzel',serif; color:#c9a84c; cursor:pointer;"
                     @onclick="StartEditName" title="Click to edit">
                @_deck.Name
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h3" Style="font-family:'Cinzel',serif; color:#c9a84c;">@_deck.Name</MudText>
        }

        <div class="d-flex align-center gap-2 mt-1">
            <FormatBadge Format="@_deck.Format" />
            @if (!_isOwner)
            {
                <MudText Typo="Typo.caption" Style="color:#9e94c8;">by @_deck.OwnerUsername</MudText>
            }
            <MudText Typo="Typo.caption" Style="color:#9e94c8;">@TotalCards cards</MudText>
        </div>

        @if (_isOwner && _editingDescription)
        {
            <MudTextField @bind-Value="_pendingDescription" Variant="Variant.Text"
                          Placeholder="Add a description..." Style="color:#9e94c8; margin-top:2px;"
                          OnBlur="SaveDescription" />
        }
        else if (_isOwner)
        {
            <MudText Typo="Typo.body2" Style="color:#9e94c8; cursor:pointer; margin-top:2px;"
                     @onclick="StartEditDescription">
                @(string.IsNullOrWhiteSpace(_deck.Description) ? "Add a description..." : _deck.Description)
            </MudText>
        }
        else if (!string.IsNullOrWhiteSpace(_deck.Description))
        {
            <MudText Typo="Typo.body2" Style="color:#9e94c8; margin-top:2px;">@_deck.Description</MudText>
        }
    </div>

    <div class="d-flex gap-2">
        @if (_isOwner || !string.IsNullOrWhiteSpace(_deck.Primer))
        {
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.HistoryEdu"
                       Style="color:#9e94c8; border-color:#3d2d5e;"
                       OnClick='() => Nav.NavigateTo($"/decks/{Id}/primer")'>
                Primer
            </MudButton>
        }
        @if (_isOwner)
        {
            <MudMenu AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                <ActivatorContent>
                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@VisibilityIcon(_deck.Visibility)"
                               EndIcon="@Icons.Material.Filled.ArrowDropDown"
                               Style="color:#9e94c8; border-color:#3d2d5e;">
                        @_deck.Visibility
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    @foreach (var v in Enum.GetValues<Visibility>())
                    {
                        var vis = v;
                        <MudMenuItem OnClick="() => ChangeVisibility(vis)"
                                     Disabled="vis == _deck.Visibility">
                            <MudIcon Icon="@VisibilityIcon(vis)" Size="Size.Small" Class="mr-2" />
                            @vis
                        </MudMenuItem>
                    }
                </ChildContent>
            </MudMenu>
            <MudButton Variant="Variant.Outlined" OnClick="OpenBulkImport">Bulk Import</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCards"
                       Disabled="_saving">
                @(_saving ? "Saving..." : "Save Deck")
            </MudButton>
        }
    </div>
</div>

@if (_isOwner && _validationErrors.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        @foreach (var e in _validationErrors) { <div>@e</div> }
    </MudAlert>
}

@if (_isOwner)
{
    <!-- Edit mode: search panel + deck list -->
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudCard Style="background:#241a35; border:1px solid #3d2d5e; position:sticky; top:16px;">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3" Style="font-family:'Cinzel',serif;">Add Cards</MudText>
                    <MudTextField T="string" Value="_searchQuery" ValueChanged="OnSearchInput"
                                  Label="Search cards..."
                                  Variant="Variant.Outlined" FullWidth="true"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="300" />

                    @if (_searchResults.Count > 0)
                    {
                        <MudList T="CardSearchResult" Class="mt-2"
                                 Style="background:#1c1228; border:1px solid #3d2d5e; border-radius:4px; max-height:400px; overflow-y:auto;">
                            @foreach (var card in _searchResults)
                            {
                                <MudListItem T="CardSearchResult" OnClick="() => AddCard(card)"
                                             Style="border-bottom:1px solid #2a1d40; cursor:pointer;">
                                    <MudMenu PositionAtCursor="true" Dense="true"
                                             PopoverClass="wander-context-menu">
                                        <ActivatorContent Context="menuCtx">
                                            <div @oncontextmenu="e => menuCtx.OpenAsync(e)"
                                                 @oncontextmenu:preventDefault="true"
                                                 @oncontextmenu:stopPropagation="true"
                                                 class="card-row-activator">
                                                <div class="d-flex justify-space-between align-center">
                                                    <MudText Typo="Typo.body2">@card.Name</MudText>
                                                    <ManaCost Cost="@card.ManaCost" />
                                                </div>
                                                <MudText Typo="Typo.caption" Style="color:#9e94c8;">@card.TypeLine</MudText>
                                            </div>
                                        </ActivatorContent>
                                        <ChildContent>
                                            <MudMenuItem Icon="@Icons.Material.Filled.Add"
                                                         OnClick="() => AddCard(card)">
                                                Add to Deck
                                            </MudMenuItem>
                                            <MudMenuItem Icon="@Icons.Material.Filled.SwapHoriz"
                                                         OnClick="() => AddToSideboard(card)">
                                                Add to Sideboard
                                            </MudMenuItem>
                                            @if (card.TypeLine.Contains("Legendary", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <MudMenuItem Icon="@Icons.Material.Filled.Star"
                                                             OnClick="() => AddAsCommander(card)">
                                                    Add as Commander
                                                </MudMenuItem>
                                            }
                                        </ChildContent>
                                    </MudMenu>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="8">
            @if (_deck.Format == Format.Commander)
            {
                var commanders = _localCards.Where(c => c.IsCommander).ToList();
                <MudCard Style="background:#1e1030; border:1px solid #c9a84c44; margin-bottom:16px;">
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Class="mb-2"
                                 Style="font-family:'Cinzel',serif; color:#c9a84c;">
                            Command Zone
                        </MudText>
                        @if (commanders.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color:#9e94c8; font-style:italic;">
                                Search for a legendary creature and right-click to set as commander.
                            </MudText>
                        }
                        @foreach (var card in commanders)
                        {
                            <CardRow Card="@card" ShowRemove="true"
                                     Context="CardContext.BuilderCommander"
                                     OnRemove="RemoveCard"
                                     OnMoveToMain="DemoteCommander" />
                        }
                    </MudCardContent>
                </MudCard>
            }

            @foreach (var group in GroupedCards)
            {
                <MudCard Style="background:#241a35; border:1px solid #3d2d5e; margin-bottom:12px;">
                    <MudCardContent>
                        <div class="d-flex align-center mb-2">
                            <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif;">@group.Key</MudText>
                            <MudText Typo="Typo.caption" Class="ml-2" Style="color:#9e94c8;">
                                (@group.Sum(c => c.Quantity))
                            </MudText>
                        </div>
                        @foreach (var card in group.OrderBy(c => c.Cmc).ThenBy(c => c.CardName))
                        {
                            <CardRow Card="@card" ShowQuantityControl="true" ShowRemove="true"
                                     Context="CardContext.BuilderMain"
                                     OnIncrement="IncrementCard" OnDecrement="DecrementCard"
                                     OnRemove="RemoveCard" OnSetCommander="SetAsCommander"
                                     OnMoveToSideboard="MoveToSideboard" OnMoveToMain="MoveToMain" />
                        }
                    </MudCardContent>
                </MudCard>
            }
        </MudItem>
    </MudGrid>
}
else
{
    <!-- View mode: card list + stats -->
    <MudGrid>
        <MudItem xs="12" md="7">
            @if (_deck.Format == Format.Commander)
            {
                var commanders = _localCards.Where(c => c.IsCommander).ToList();
                @if (commanders.Count > 0)
                {
                    <MudCard Style="background:#1e1030; border:1px solid #c9a84c44; margin-bottom:16px;">
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Class="mb-2"
                                     Style="font-family:'Cinzel',serif; color:#c9a84c;">
                                Command Zone
                            </MudText>
                            @foreach (var card in commanders)
                            {
                                <CardRow Card="@card" Context="CardContext.Viewer"
                                         OnOpenScryfall="() => OpenScryfall(card)" />
                            }
                        </MudCardContent>
                    </MudCard>
                }
            }

            @foreach (var group in GroupedCards)
            {
                <MudCard Style="background:#241a35; border:1px solid #3d2d5e; margin-bottom:12px;">
                    <MudCardContent>
                        <div class="d-flex align-center mb-2">
                            <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif;">@group.Key</MudText>
                            <MudText Typo="Typo.caption" Class="ml-2" Style="color:#9e94c8;">
                                (@group.Sum(c => c.Quantity))
                            </MudText>
                        </div>
                        @foreach (var card in group.OrderBy(c => c.Cmc).ThenBy(c => c.CardName))
                        {
                            <CardRow Card="@card" Context="CardContext.Viewer"
                                     OnOpenScryfall="() => OpenScryfall(card)" />
                        }
                    </MudCardContent>
                </MudCard>
            }
        </MudItem>

        <MudItem xs="12" md="5">
            <MudCard Style="background:#241a35; border:1px solid #3d2d5e; margin-bottom:16px;">
                <MudCardContent>
                    <MudText Typo="Typo.h6" Class="mb-3" Style="font-family:'Cinzel',serif;">Mana Curve</MudText>
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@ManaCurveSeries"
                              ChartLabels="@ManaCurveLabels"
                              Height="160"
                              ChartOptions="@(new BarChartOptions { YAxisTicks = 1 })" />
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    DeckDetail? _deck;
    List<DeckCardDetail> _localCards = [];
    List<CardSearchResult> _searchResults = [];
    List<string> _validationErrors = [];
    string _searchQuery = "";
    bool _saving, _isOwner;

    string _pendingName = "", _pendingDescription = "";
    bool _editingName, _editingDescription, _savingMeta;

    int TotalCards => _localCards.Where(c => !c.IsCommander).Sum(c => c.Quantity);

    IEnumerable<IGrouping<string, DeckCardDetail>> GroupedCards =>
        _localCards
            .Where(c => !c.IsCommander && !c.IsSideboard)
            .GroupBy(c => GetTypeGroup(c.TypeLine))
            .OrderBy(g => TypeGroupOrder(g.Key));

    List<ChartSeries<double>> ManaCurveSeries => [new ChartSeries<double>
    {
        Name = "Cards",
        Data = Enumerable.Range(0, 8)
            .Select(cmc => (double)(_localCards
                .Where(c => !c.IsCommander && !c.IsSideboard &&
                    (cmc == 7 ? c.Cmc >= 7 : (int)c.Cmc == cmc))
                .Sum(c => c.Quantity)))
            .ToArray()
    }];

    string[] ManaCurveLabels = ["0", "1", "2", "3", "4", "5", "6", "7+"];

    protected override async Task OnInitializedAsync()
    {
        _deck = await Api.GetDeckAsync(Id);
        if (_deck != null)
        {
            _localCards = _deck.Cards.ToList();
            var authState = await AuthState.GetAuthenticationStateAsync();
            _isOwner = authState.User.Identity?.IsAuthenticated == true
                       && _deck.OwnerUsername == authState.User.Identity.Name;
        }
    }

    // ── Name / description inline editing ────────────────────────────────────

    void StartEditName()
    {
        _pendingName = _deck!.Name;
        _editingName = true;
    }

    void StartEditDescription()
    {
        _pendingDescription = _deck!.Description ?? "";
        _editingDescription = true;
    }

    async Task SaveName(FocusEventArgs _)
    {
        _editingName = false;
        var trimmed = _pendingName.Trim();
        if (trimmed == _deck!.Name) return;

        var error = InputValidator.Validate(trimmed, TextFieldType.Generic)
                    ?? (trimmed.Length > 200 ? "Name must be at most 200 characters." : null);
        if (error != null) { Snackbar.Add(error, Severity.Warning); return; }

        if (_savingMeta) return;
        _savingMeta = true;
        try
        {
            var response = await Api.UpdateDeckAsync(Id, new UpdateDeckRequest(
                trimmed, _deck.Description, _deck.Primer, _deck.Format, _deck.Visibility));
            if (response.IsSuccessStatusCode)
                _deck = _deck with { Name = trimmed };
            else
                Snackbar.Add("Failed to save deck name.", Severity.Error);
        }
        finally { _savingMeta = false; }
    }

    async Task SaveDescription(FocusEventArgs _)
    {
        _editingDescription = false;
        var trimmed = _pendingDescription.Trim();
        var current = _deck!.Description ?? "";
        if (trimmed == current) return;

        if (!string.IsNullOrEmpty(trimmed))
        {
            var error = InputValidator.Validate(trimmed, TextFieldType.Generic)
                        ?? (trimmed.Length > 1000 ? "Description must be at most 1000 characters." : null);
            if (error != null) { Snackbar.Add(error, Severity.Warning); return; }
        }

        if (_savingMeta) return;
        _savingMeta = true;
        try
        {
            var newDesc = string.IsNullOrEmpty(trimmed) ? null : trimmed;
            var response = await Api.UpdateDeckAsync(Id, new UpdateDeckRequest(
                _deck.Name, newDesc, _deck.Primer, _deck.Format, _deck.Visibility));
            if (response.IsSuccessStatusCode)
                _deck = _deck with { Description = newDesc };
            else
                Snackbar.Add("Failed to save description.", Severity.Error);
        }
        finally { _savingMeta = false; }
    }

    // ── Card search ───────────────────────────────────────────────────────────

    async Task OnSearchInput(string q)
    {
        _searchQuery = q;
        if (q.Length < 2) { _searchResults = []; return; }
        _searchResults = await Api.SearchCardsAsync(q);
    }

    // ── Card mutations ────────────────────────────────────────────────────────

    void AddCard(CardSearchResult card)
    {
        var existing = _localCards.FirstOrDefault(c => c.CardId == card.Id && !c.IsCommander);
        if (existing != null)
            _localCards = _localCards.Select(c => c == existing
                ? c with { Quantity = c.Quantity + 1 } : c).ToList();
        else
            _localCards.Add(new DeckCardDetail(Guid.NewGuid(), card.Id, card.DefaultPrintingId, card.Name, card.ManaCost,
                card.Cmc, card.TypeLine, card.ColorIdentity, card.ImageUriNormal, card.ImageUriSmall,
                1, false, false, []));
    }

    void AddToSideboard(CardSearchResult card)
    {
        var existing = _localCards.FirstOrDefault(c => c.CardId == card.Id && c.IsSideboard);
        if (existing != null)
            _localCards = _localCards.Select(c => c == existing
                ? c with { Quantity = c.Quantity + 1 } : c).ToList();
        else
            _localCards.Add(new DeckCardDetail(Guid.NewGuid(), card.Id, card.DefaultPrintingId, card.Name, card.ManaCost,
                card.Cmc, card.TypeLine, card.ColorIdentity, card.ImageUriNormal, card.ImageUriSmall,
                1, false, true, []));
    }

    void AddAsCommander(CardSearchResult card)
    {
        if (_localCards.Any(c => c.CardId == card.Id && c.IsCommander)) return;
        _localCards.Add(new DeckCardDetail(Guid.NewGuid(), card.Id, card.DefaultPrintingId, card.Name, card.ManaCost,
            card.Cmc, card.TypeLine, card.ColorIdentity, card.ImageUriNormal, card.ImageUriSmall,
            1, true, false, []));
    }

    void SetAsCommander(DeckCardDetail card)
    {
        if (_localCards.Any(c => c.CardId == card.CardId && c.IsCommander)) return;
        _localCards.Add(card with { Id = Guid.NewGuid(), IsCommander = true, Quantity = 1 });
    }

    void MoveToSideboard(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { IsSideboard = true } : c).ToList();

    void MoveToMain(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { IsSideboard = false } : c).ToList();

    void DemoteCommander(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { IsCommander = false } : c).ToList();

    void IncrementCard(DeckCardDetail card) =>
        _localCards = _localCards.Select(c => c == card ? c with { Quantity = c.Quantity + 1 } : c).ToList();

    void DecrementCard(DeckCardDetail card)
    {
        if (card.Quantity <= 1) RemoveCard(card);
        else _localCards = _localCards.Select(c => c == card ? c with { Quantity = c.Quantity - 1 } : c).ToList();
    }

    void RemoveCard(DeckCardDetail card) => _localCards.Remove(card);

    // ── Save ──────────────────────────────────────────────────────────────────

    async Task SaveCards()
    {
        _saving = true;
        var requests = _localCards.Select(c =>
            new DeckCardRequest(c.CardId, c.PrintingId, c.Quantity, c.IsCommander, c.IsSideboard)).ToList();
        var response = await Api.SetCardsAsync(Id, requests);
        if (!response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadFromJsonAsync<Dictionary<string, List<string>>>();
            _validationErrors = body?.GetValueOrDefault("errors") ?? ["Save failed."];
        }
        else
        {
            _validationErrors = [];
            Snackbar.Add("Deck saved.", Severity.Success);
        }
        _saving = false;
    }

    async Task OpenBulkImport()
    {
        var dialog = await Dialogs.ShowAsync<Dialogs.BulkImportDialog>("Bulk Import",
            new DialogParameters<Dialogs.BulkImportDialog> { { d => d.DeckId, Id } });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is DeckDetail updated)
        {
            _localCards = updated.Cards.ToList();
            _validationErrors = [];
        }
    }

    // ── Scryfall ──────────────────────────────────────────────────────────────

    async Task OpenScryfall(DeckCardDetail card) =>
        await JS.InvokeVoidAsync("open",
            $"https://scryfall.com/search?q=!\"{Uri.EscapeDataString(card.CardName)}\"", "_blank");

    // ── Visibility ────────────────────────────────────────────────────────────

    static string VisibilityIcon(Visibility v) => v switch
    {
        Visibility.Public   => Icons.Material.Filled.Public,
        Visibility.Private  => Icons.Material.Filled.Lock,
        Visibility.Unlisted => Icons.Material.Filled.Link,
        _                   => Icons.Material.Filled.Visibility,
    };

    async Task ChangeVisibility(Visibility newVis)
    {
        if (_deck == null || newVis == _deck.Visibility) return;
        var response = await Api.UpdateDeckAsync(Id, new UpdateDeckRequest(
            _deck.Name, _deck.Description, _deck.Primer, _deck.Format, newVis));
        if (response.IsSuccessStatusCode)
        {
            _deck = _deck with { Visibility = newVis };
            Snackbar.Add($"Visibility set to {newVis}.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to update visibility.", Severity.Error);
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    static string GetTypeGroup(string typeLine) =>
        new[] { "Creature", "Instant", "Sorcery", "Enchantment", "Artifact", "Planeswalker", "Battle", "Land" }
            .FirstOrDefault(t => typeLine.Contains(t, StringComparison.OrdinalIgnoreCase)) ?? "Other";

    static int TypeGroupOrder(string group) =>
        group switch
        {
            "Creature"     => 0, "Instant"      => 1, "Sorcery"    => 2, "Enchantment" => 3,
            "Artifact"     => 4, "Planeswalker" => 5, "Battle"     => 6, "Land"        => 7,
            _              => 8,
        };
}
