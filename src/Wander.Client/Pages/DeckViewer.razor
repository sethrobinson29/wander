@page "/decks/{Id:guid}"
@inject WanderApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService Dialogs
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthState
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using MudBlazor.Charts

@if (_deck == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    return;
}
<!-- Cover Banner -->
<div @ref="_bannerRef" style="height:200px;border-radius:8px;margin-bottom:16px;position:relative;@ColorIdentityHelper.BannerStyle(
             CommanderColors,
             _deck.Format == Format.Commander ? _deck.CoverImageUri : null,
             _deck.CoverCropLeft, _deck.CoverCropTop,
             _deck.CoverCropWidth, _deck.CoverCropHeight)">
    @if (_isOwner && _deck.Format == Format.Commander)
    {
        <MudIconButton Icon="@Icons.Material.Filled.Image" Size="Size.Small"
                       Style="position:absolute;bottom:8px;right:8px;background:rgba(0,0,0,0.45);color:#c4a35f;"
                       OnClick="OpenCoverPicker"
                       title="@(_deck.CoverImageUri != null ? "Change cover" : "Set cover")" />
    }
</div>

<!-- Header -->
<div class="d-flex justify-space-between align-center mb-4">
    <div>
        @if (_isOwner && _editingName)
        {
            <MudTextField @bind-Value="_pendingName" Variant="Variant.Text" AutoFocus="true"
                          Style="font-family:'Cinzel',serif; color:#c4a35f; font-size:1.5rem; font-weight:400;"
                          OnBlur="SaveName" />
        }
        else if (_isOwner)
        {
            <MudText Typo="Typo.h4" Style="font-family:'Cinzel',serif; color:#c4a35f; cursor:pointer;"
                     @onclick="StartEditName" title="Click to edit">
                @_deck.Name
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.h3" Style="font-family:'Cinzel',serif; color:#c4a35f;">@_deck.Name</MudText>
        }

        <div class="d-flex align-center gap-2 mt-1">
            <FormatBadge Format="@_deck.Format" />
            @if (!_isOwner)
            {
                <MudLink Href="@($"/users/{_deck.OwnerUsername}")" Typo="Typo.caption" Style="color:#948aa8;">by @_deck.OwnerUsername</MudLink>
            }
            <MudText Typo="Typo.caption" Style="color:#948aa8;">@TotalCards cards</MudText>
        </div>

        @if (_isOwner && _editingDescription)
        {
            <MudTextField @bind-Value="_pendingDescription" Variant="Variant.Text"
                          Placeholder="Add a description..." Style="color:#948aa8; margin-top:2px;"
                          OnBlur="SaveDescription" />
        }
        else if (_isOwner)
        {
            <MudText Typo="Typo.body2" Style="color:#948aa8; cursor:pointer; margin-top:2px;"
                     @onclick="StartEditDescription">
                @(string.IsNullOrWhiteSpace(_deck.Description) ? "Add a description..." : _deck.Description)
            </MudText>
        }
        else if (!string.IsNullOrWhiteSpace(_deck.Description))
        {
            <MudText Typo="Typo.body2" Style="color:#948aa8; margin-top:2px;">@_deck.Description</MudText>
        }
    </div>

    <div class="d-flex gap-2">
        @if (!_isOwner)
        {
            <MudButton Variant="@(_isLiked? Variant.Filled: Variant.Outlined)"
                       StartIcon="@(_isLiked ? Icons.Material.Filled.Favorite : Icons.Material.Outlined.FavoriteBorder)"
                       Style="@(_isLiked ? "color:white;" : "color:#948aa8; border-color:#352d47;")"
                       Disabled="_likeBusy || !_isAuthenticated"
                       OnClick="ToggleLike">
                @_likeCount
            </MudButton>
            <MudButton Variant="Variant.Outlined" Style="color:#948aa8; border-color:#352d47;"
                       OnClick="OpenBulkExport">Export</MudButton>
        }
        else
        {
            <div class="d-flex align-center gap-1" style="color:#948aa8; padding:6px 8px;">
                <MudIcon Icon="@Icons.Material.Filled.Favorite" Size="Size.Small" />
                <MudText Typo="Typo.body2">@_likeCount</MudText>
            </div>
        }
        @if (_isOwner || !string.IsNullOrWhiteSpace(_deck.Primer))
        {
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.HistoryEdu"
                       Style="color:#948aa8; border-color:#352d47;"
                       OnClick='() => Nav.NavigateTo($"/decks/{Id}/primer")'>
                Primer
            </MudButton>
        }
        @if (_isOwner)
        {
            <MudMenu Label="@_deck.Visibility.ToString()"
                     StartIcon="@VisibilityIcon(_deck.Visibility)"
                     EndIcon="@Icons.Material.Filled.ArrowDropDown"
                     Variant="Variant.Outlined"
                     Style="color:#948aa8; border-color:#352d47;"
                     AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                @foreach (var v in Enum.GetValues<Visibility>())
                {
                    var vis = v;
                    <MudMenuItem OnClick="() => ChangeVisibility(vis)"
                                 Disabled="vis == _deck.Visibility">
                        <MudIcon Icon="@VisibilityIcon(vis)" Size="Size.Small" Class="mr-2" />
                        @vis
                    </MudMenuItem>
                }
            </MudMenu>
            <MudButton Variant="Variant.Outlined" OnClick="OpenBulkExport">Export</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="OpenBulkImport">Bulk Import</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCards"
                       Disabled="_saving">
                @(_saving ? "Saving..." : "Save Deck")
            </MudButton>
        }
    </div>
</div>

<div class="d-flex gap-2 mb-3 align-center">
    <MudSelect T="DeckGroupBy" @bind-Value="_groupBy" Label="Group by"
               Variant="Variant.Outlined" Dense="true" Style="max-width:160px;">
        <MudSelectItem Value="DeckGroupBy.Type">Type</MudSelectItem>
        <MudSelectItem Value="DeckGroupBy.ManaValue">Mana Value</MudSelectItem>
        <MudSelectItem Value="DeckGroupBy.Color">Color</MudSelectItem>
        <MudSelectItem Value="DeckGroupBy.ColorIdentity">Color Identity</MudSelectItem>
        <MudSelectItem Value="DeckGroupBy.None">None</MudSelectItem>
    </MudSelect>
    <MudSelect T="DeckSortBy" @bind-Value="_sortBy" Label="Sort by"
               Variant="Variant.Outlined" Dense="true" Style="max-width:160px;">
        <MudSelectItem Value="DeckSortBy.ManaValue">Mana Value</MudSelectItem>
        <MudSelectItem Value="DeckSortBy.Name">Name</MudSelectItem>
    </MudSelect>
</div>

@if (_isOwner && _validationErrors.Count > 0)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        @foreach (var e in _validationErrors) { <div>@e</div> }
    </MudAlert>
}

@if (_isOwner)
{
    <!-- Edit mode: search panel + deck list -->
    <MudGrid>
        <MudItem xs="12" md="4">
            <div style="position:sticky;top:16px;">
            <MudPaper Class="mb-4" Style="border:1px solid #352d47;">
                <div class="pa-3" style="border-bottom:1px solid #352d47;">
                    <span class="wander-display" style="color:#c4a35f;font-size:14px;letter-spacing:0.08em;">Add Cards</span>
                </div>
                <div class="pa-3">
                <div @onfocusout="OnSearchFocusOut" tabindex="-1">
                    <MudTextField T="string" Value="_searchQuery" ValueChanged="OnSearchInput"
                                  Label="Search cards..."
                                  Variant="Variant.Outlined" FullWidth="true"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Search"
                                  DebounceInterval="300" />

                    @if (_searchResults.Count > 0)
                    {
                        <MudList T="CardSearchResult" Class="mt-2"
                                 Style="background:#14101e; border:1px solid #352d47; border-radius:4px; max-height:400px; overflow-y:auto;">
                            @foreach (var card in _searchResults)
                            {
                                <MudListItem T="CardSearchResult" OnClick="() => AddCard(card)"
                                             Style="border-bottom:1px solid #251f31; cursor:pointer;">
                                    <div @oncontextmenu="e => OpenSearchCtx(e, card)"
                                         @oncontextmenu:preventDefault="true"
                                         class="card-row-activator">
                                        <div class="d-flex justify-space-between align-center">
                                            <MudText Typo="Typo.body2">@card.Name</MudText>
                                            <ManaCost Cost="@card.ManaCost" />
                                        </div>
                                        <MudText Typo="Typo.caption" Style="color:#948aa8;">@card.TypeLine</MudText>
                                    </div>
                                </MudListItem>
                            }
                        </MudList>
                    }
                    </div>
                    @if (_ctxOpen && _ctxCard != null)
                    {
                        <div style="position:fixed;inset:0;z-index:1199"
                             @onclick="CloseSearchCtx"
                             @oncontextmenu="CloseSearchCtx"
                             @oncontextmenu:preventDefault="true" />
                        <div class="wander-context-menu" style="position:fixed;left:@_ctxX;top:@_ctxY;">
                            <div class="wander-ctx-item"
                                 @onclick="() => { AddCard(_ctxCard!); CloseSearchCtx(); }">
                                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                                Add to Deck
                            </div>
                            <div class="wander-ctx-item"
                                 @onclick="() => { AddToSideboard(_ctxCard!); CloseSearchCtx(); }">
                                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                                Add to Sideboard
                            </div>
                            @if (_ctxCard!.TypeLine.Contains("Legendary", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="wander-ctx-item"
                                     @onclick="() => { AddAsCommander(_ctxCard!); CloseSearchCtx(); }">
                                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color:#c4a35f;" />
                                    Add as Commander
                                </div>
                            }
                        <div class="wander-ctx-item"
                             @onclick='async () => { CloseSearchCtx(); await JS.InvokeVoidAsync("copyToClipboard", _ctxCard!.Name); }'>
                            <MudIcon Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small" />
                            Copy Card Name
                        </div>
                        <div class="wander-ctx-item"
                             @onclick="async () => { CloseSearchCtx(); await OpenViewDetailsFromSearch(_ctxCard!); }">
                            <MudIcon Icon="@Icons.Material.Outlined.Info" Size="Size.Small" />
                            View Details
                        </div>
                        </div>
                    }
                </div>
            </MudPaper>
            <MudPaper Style="border:1px solid #352d47;">
                <div class="pa-3" style="border-bottom:1px solid #352d47;">
                    <span class="wander-label">Mana Curve</span>
                </div>
                <div class="pa-3">
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@ManaCurveSeries"
                              ChartLabels="@ManaCurveLabels"
                              Height="120"
                              ChartOptions="@(new BarChartOptions { YAxisTicks = 1 })" />
                </div>
            </MudPaper>
            </div>
        </MudItem>

        <MudItem xs="12" md="8">
            @if (_deck.Format == Format.Commander)
            {
                var commanders = _localCards.Where(c => c.IsCommander).ToList();
                <MudPaper Class="mb-3" Style="border:1px solid #c4a35f44;">
                    <div class="pa-3 d-flex align-center" style="background:rgba(196,163,95,0.07);border-bottom:1px solid #c4a35f44;border-radius:8px 8px 0 0;">
                        <span class="wander-display" style="font-size:13px;letter-spacing:0.1em;text-transform:uppercase;color:#c4a35f;">Command Zone</span>
                    </div>
                    @if (commanders.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="pa-3" Style="color:#948aa8;font-style:italic;">
                            Right-click any card and select Make Commander.
                        </MudText>
                    }
                    @foreach (var card in commanders)
                    {
                        <CardRow Card="@card" ShowRemove="true"
                                 Context="CardContext.BuilderCommander"
                                 OnRemove="RemoveCard"
                                 OnMoveToMain="DemoteCommander"
                                 OnViewDetails="OpenViewDetails"
                                 OnSwitchPrinting="OpenSwitchPrinting"
                                 OnSetAsImage="OpenSetAsImage" />
                        @if (!IsLegalCommander(card))
                        {
                            <div class="d-flex align-center gap-1 px-3"
                                 style="color:#f6a823;font-size:0.75rem;margin-top:-4px;margin-bottom:4px;">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                Not a legal commander
                            </div>
                        }
                    }
                </MudPaper>
            }

            @foreach (var group in GroupedCards)
            {
                <MudPaper Class="mb-3" Style="border:1px solid #352d47;">
                    <div class="pa-3 d-flex align-center" style="border-bottom:1px solid #352d47;">
                        <span class="wander-display" style="font-size:13px;letter-spacing:0.1em;text-transform:uppercase;">@group.Key</span>
                        <span class="ml-2 wander-tnum" style="color:#645a76;font-size:12px;">@group.Sum(c => c.Quantity)</span>
                    </div>
                    @foreach (var card in SortCards(group))
                    {
                        <CardRow Card="@card" ShowQuantityControl="true" ShowRemove="true"
                                 Context="CardContext.BuilderMain"
                                 OnIncrement="IncrementCard" OnDecrement="DecrementCard"
                                 OnRemove="RemoveCard" OnMakeCommander="MakeCommander" OnAddMore="AddMore"
                                 OnMoveToSideboard="MoveToSideboard" OnMoveToMain="MoveToMain"
                                 OnViewDetails="OpenViewDetails"
                                 OnSwitchPrinting="OpenSwitchPrinting"
                                 OnSetAsImage="OpenSetAsImage" />
                        @if (IsOutsideColorIdentity(card))
                        {
                            <div class="d-flex align-center gap-1 px-3"
                                 style="color:#f6a823;font-size:0.75rem;margin-top:-4px;margin-bottom:4px;">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                Outside commander's color identity
                            </div>
                        }
                    }
                </MudPaper>
            }

            @{
                var sideboardCards = _localCards.Where(c => c.IsSideboard).ToList();
            }
            @if (sideboardCards.Count > 0)
            {
                <MudPaper Class="mb-3" Style="border:1px solid #352d47;">
                    <div class="pa-3 d-flex align-center" style="border-bottom:1px solid #352d47;">
                        <span class="wander-display" style="font-size:13px;letter-spacing:0.1em;text-transform:uppercase;">Sideboard</span>
                        <span class="ml-2 wander-tnum" style="color:#645a76;font-size:12px;">@sideboardCards.Sum(c => c.Quantity)</span>
                    </div>
                    @foreach (var card in SortCards(sideboardCards))
                    {
                        <CardRow Card="@card" ShowQuantityControl="true" ShowRemove="true"
                                 Context="CardContext.BuilderMain"
                                 OnIncrement="IncrementCard" OnDecrement="DecrementCard"
                                 OnRemove="RemoveCard" OnMakeCommander="MakeCommander" OnAddMore="AddMore"
                                 OnMoveToMain="MoveToMain"
                                 OnViewDetails="OpenViewDetails"
                                 OnSwitchPrinting="OpenSwitchPrinting"
                                 OnSetAsImage="OpenSetAsImage" />
                        @if (IsOutsideColorIdentity(card))
                        {
                            <div class="d-flex align-center gap-1 px-3"
                                 style="color:#f6a823;font-size:0.75rem;margin-top:-4px;margin-bottom:4px;">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                Outside commander's color identity
                            </div>
                        }
                    }
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
}
else
{
    <!-- View mode: card list + stats -->
    <MudGrid>
        <MudItem xs="12" md="7">
            @if (_deck.Format == Format.Commander)
            {
                var commanders = _localCards.Where(c => c.IsCommander).ToList();
                @if (commanders.Count > 0)
                {
                    <MudPaper Class="mb-3" Style="border:1px solid #c4a35f44;">
                        <div class="pa-3 d-flex align-center" style="background:rgba(196,163,95,0.07);border-bottom:1px solid #c4a35f44;border-radius:8px 8px 0 0;">
                            <span class="wander-display" style="font-size:13px;letter-spacing:0.1em;text-transform:uppercase;color:#c4a35f;">Command Zone</span>
                        </div>
                        @foreach (var card in commanders)
                        {
                            <CardRow Card="@card" Context="CardContext.Viewer"
                                     OnOpenScryfall="() => OpenScryfall(card)"
                                     OnViewDetails="OpenViewDetails" />
                            @if (!IsLegalCommander(card))
                            {
                                <div class="d-flex align-center gap-1 px-3"
                                     style="color:#f6a823;font-size:0.75rem;margin-top:-4px;margin-bottom:4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                    Not a legal commander
                                </div>
                            }
                        }
                    </MudPaper>
                }
            }

            @foreach (var group in GroupedCards)
            {
                <MudPaper Class="mb-3" Style="border:1px solid #352d47;">
                    <div class="pa-3 d-flex align-center" style="border-bottom:1px solid #352d47;">
                        <span class="wander-display" style="font-size:13px;letter-spacing:0.1em;text-transform:uppercase;">@group.Key</span>
                        <span class="ml-2 wander-tnum" style="color:#645a76;font-size:12px;">@group.Sum(c => c.Quantity)</span>
                    </div>
                    @foreach (var card in SortCards(group))
                    {
                        <CardRow Card="@card" Context="CardContext.Viewer"
                                 OnOpenScryfall="() => OpenScryfall(card)"
                                 OnViewDetails="OpenViewDetails" />
                        @if (IsOutsideColorIdentity(card))
                        {
                            <div class="d-flex align-center gap-1 px-3"
                                 style="color:#f6a823;font-size:0.75rem;margin-top:-4px;margin-bottom:4px;">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                Outside commander's color identity
                            </div>
                        }
                    }
                </MudPaper>
            }

            @{
                var sideboardCards = _localCards.Where(c => c.IsSideboard).ToList();
            }
            @if (sideboardCards.Count > 0)
            {
                <MudPaper Class="mb-3" Style="border:1px solid #352d47;">
                    <div class="pa-3 d-flex align-center" style="border-bottom:1px solid #352d47;">
                        <span class="wander-display" style="font-size:13px;letter-spacing:0.1em;text-transform:uppercase;">Sideboard</span>
                        <span class="ml-2 wander-tnum" style="color:#645a76;font-size:12px;">@sideboardCards.Sum(c => c.Quantity)</span>
                    </div>
                    @foreach (var card in SortCards(sideboardCards))
                    {
                        <CardRow Card="@card" Context="CardContext.Viewer"
                                 OnOpenScryfall="() => OpenScryfall(card)"
                                 OnViewDetails="OpenViewDetails" />
                        @if (IsOutsideColorIdentity(card))
                        {
                            <div class="d-flex align-center gap-1 px-3"
                                 style="color:#f6a823;font-size:0.75rem;margin-top:-4px;margin-bottom:4px;">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                                Outside commander's color identity
                            </div>
                        }
                    }
                </MudPaper>
            }
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Style="border:1px solid #352d47;margin-bottom:16px;">
                <div class="pa-3" style="border-bottom:1px solid #352d47;">
                    <span class="wander-label">Mana Curve</span>
                </div>
                <div class="pa-3">
                    <MudChart ChartType="ChartType.Bar"
                              ChartSeries="@ManaCurveSeries"
                              ChartLabels="@ManaCurveLabels"
                              Height="160"
                              ChartOptions="@(new BarChartOptions { YAxisTicks = 1 })" />
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

<CommentSection DeckId="@_deck.Id" OwnerId="@_ownerId" />

@code {
    [Parameter] public Guid Id { get; set; }

    DeckDetail? _deck;
    List<DeckCardDetail> _localCards = [];
    List<CardSearchResult> _searchResults = [];
    List<string> _validationErrors = [];
    string _searchQuery = "";
    bool _saving, _isOwner, _isLiked, _likeBusy, _isAuthenticated;
    int _likeCount;
    string _ownerId = "";

    ElementReference _bannerRef;
    record BannerRect(double Left, double Top, double Width, double Height);

    CardSearchResult? _ctxCard;
    string _ctxX = "0px", _ctxY = "0px";
    bool _ctxOpen;

    string _pendingName = "", _pendingDescription = "";
    bool _editingName, _editingDescription, _savingMeta;

    int TotalCards => _localCards.Where(c => !c.IsSideboard).Sum(c => c.Quantity);

    IEnumerable<string> CommanderColors
    {
        get
        {
            var colors = _localCards.Where(c => c.IsCommander).SelectMany(c => c.ColorIdentity).ToList();
            if (!colors.Any()) colors = _localCards.SelectMany(c => c.ColorIdentity).ToList();
            return colors.Distinct().OrderBy(c => "WUBRG".IndexOf(c, StringComparison.Ordinal));
        }
    }

    DeckGroupBy _groupBy = DeckGroupBy.Type;
    DeckSortBy  _sortBy  = DeckSortBy.ManaValue;

    IEnumerable<IGrouping<string, DeckCardDetail>> GroupedCards =>
        _localCards
            .Where(c => !c.IsCommander && !c.IsSideboard)
            .GroupBy(c => GetGroupKey(c))
            .OrderBy(g => GetGroupOrder(g.Key));

    List<ChartSeries<double>> ManaCurveSeries => [new ChartSeries<double>
    {
        Name = "Cards",
        Data = Enumerable.Range(0, 8)
            .Select(cmc => (double)(_localCards
                .Where(c => !c.IsCommander && !c.IsSideboard &&
                    !c.TypeLine.Contains("Land", StringComparison.OrdinalIgnoreCase) &&
                    (cmc == 7 ? c.Cmc >= 7 : (int)c.Cmc == cmc))
                .Sum(c => c.Quantity)))
            .ToArray()
    }];

    string[] ManaCurveLabels = ["0", "1", "2", "3", "4", "5", "6", "7+"];

    protected override async Task OnInitializedAsync()
    {
        _deck = await Api.GetDeckAsync(Id);
        if (_deck != null)
        {
            _localCards = _deck.Cards.ToList();
            _validationErrors = FilterDeckErrors(_deck.DeckErrors);
            var authState = await AuthState.GetAuthenticationStateAsync();
            _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
            _isOwner = _isAuthenticated && _deck.OwnerUsername == authState.User.Identity!.Name;
            _ownerId = _deck.OwnerId;
            _likeCount = _deck.LikeCount;
            _isLiked = _deck.IsLikedByCurrentUser;
        }
    }

    async Task ToggleLike()
    {
        if (!_isAuthenticated) return;
        _likeBusy = true;
        var wasLiked = _isLiked;
        var response = wasLiked
            ? await Api.UnlikeDeckAsync(Id)
            : await Api.LikeDeckAsync(Id);

        if (response.IsSuccessStatusCode)
        {
            _isLiked = !wasLiked;
            _likeCount += wasLiked ? -1 : 1;
        }
        else
        {
            Snackbar.Add(wasLiked ? "Failed to unlike." : "Failed to like.", Severity.Error);
        }
        _likeBusy = false;
    }

    // ── Name / description inline editing ────────────────────────────────────

    void StartEditName()
    {
        _pendingName = _deck!.Name;
        _editingName = true;
    }

    void StartEditDescription()
    {
        _pendingDescription = _deck!.Description ?? "";
        _editingDescription = true;
    }

    async Task SaveName(FocusEventArgs _)
    {
        _editingName = false;
        var trimmed = _pendingName.Trim();
        if (trimmed == _deck!.Name) return;

        var error = InputValidator.Validate(trimmed, TextFieldType.Generic)
                    ?? (trimmed.Length > 200 ? "Name must be at most 200 characters." : null);
        if (error != null) { Snackbar.Add(error, Severity.Warning); return; }

        if (_savingMeta) return;
        _savingMeta = true;
        try
        {
            var response = await Api.UpdateDeckAsync(Id, new UpdateDeckRequest(
                trimmed, _deck.Description, _deck.Primer, _deck.Format, _deck.Visibility));
            if (response.IsSuccessStatusCode)
                _deck = _deck with { Name = trimmed };
            else
                Snackbar.Add("Failed to save deck name.", Severity.Error);
        }
        finally { _savingMeta = false; }
    }

    async Task SaveDescription(FocusEventArgs _)
    {
        _editingDescription = false;
        var trimmed = _pendingDescription.Trim();
        var current = _deck!.Description ?? "";
        if (trimmed == current) return;

        if (!string.IsNullOrEmpty(trimmed))
        {
            var error = InputValidator.Validate(trimmed, TextFieldType.Generic)
                        ?? (trimmed.Length > 1000 ? "Description must be at most 1000 characters." : null);
            if (error != null) { Snackbar.Add(error, Severity.Warning); return; }
        }

        if (_savingMeta) return;
        _savingMeta = true;
        try
        {
            var newDesc = string.IsNullOrEmpty(trimmed) ? null : trimmed;
            var response = await Api.UpdateDeckAsync(Id, new UpdateDeckRequest(
                _deck.Name, newDesc, _deck.Primer, _deck.Format, _deck.Visibility));
            if (response.IsSuccessStatusCode)
                _deck = _deck with { Description = newDesc };
            else
                Snackbar.Add("Failed to save description.", Severity.Error);
        }
        finally { _savingMeta = false; }
    }

