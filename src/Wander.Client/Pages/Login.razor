@page "/login"
@inject WanderApiClient Api
@inject LocalStorage LocalStorage
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudCard Style="border: 1px solid #352d47;">
        <MudCardContent Class="pa-8">
            <MudText Typo="Typo.h4" Class="mb-6" Style="color:#c4a35f; font-family:'Cinzel',serif;">
                Sign In
            </MudText>

            <MudTextField @bind-Value="_email" Label="Email" InputType="InputType.Email"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-4"
                          Error="@(_submitted && _emailError != null)"
                          ErrorText="@_emailError" />

            <MudTextField @bind-Value="_password" Label="Password" InputType="InputType.Password"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-6"
                          Error="@(_submitted && _passwordError != null)"
                          ErrorText="@_passwordError" />

            @if (_error != null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
            }

            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="Submit" Disabled="_loading" Size="Size.Large">
                @(_loading ? "Entering..." : "Enter the Archive")
            </MudButton>

            <MudText Typo="Typo.body2" Class="mt-4 text-center">
                No account? <MudLink Href="/register" Color="Color.Primary">Register</MudLink>
            </MudText>
        </MudCardContent>
    </MudCard>
</MudContainer>

@code {
    string _email = "", _password = "", _error = null!;
    bool _loading, _submitted;
    string? _emailError, _passwordError;

    bool Validate()
    {
        _emailError    = InputValidator.Validate(_email.Trim(), TextFieldType.Email);
        _passwordError = InputValidator.Validate(_password, TextFieldType.PasswordLogin);
        return _emailError == null && _passwordError == null;
    }

    async Task Submit()
    {
        _submitted = true;
        if (!Validate()) return;
        _loading = true; _error = null!;
        var response = await Api.LoginRawAsync(_email.Trim(), _password);
        if (!response.IsSuccessStatusCode)
        {
            _error = "Invalid email or password.";
            _loading = false;
            return;
        }

        var auth = await response.Content.ReadFromJsonAsync<AuthResponse>();
        await LocalStorage.SetAsync("accessToken", auth!.AccessToken);
        await LocalStorage.SetAsync("refreshToken", auth.RefreshToken);
        ((JwtAuthStateProvider)AuthStateProvider).NotifyUserChanged();
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        Nav.NavigateTo(authState.User.IsInRole("Admin") ? "/admin" : "/decks");
    }
}