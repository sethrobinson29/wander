@page "/search"
@inject WanderApiClient Api
@inject NavigationManager Nav

<MudText Typo="Typo.h4" Class="page-title">Search Results</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_type == "user")
{
    @if (_users.Count == 0)
    {
        <MudText Style="color:#948aa8;">No users found for "@Q".</MudText>
    }
    else
    {
        <MudGrid>
            @foreach (var user in _users)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Style="border:1px solid #352d47; cursor:pointer;" Class="deck-card"
                             @onclick='() => Nav.NavigateTo($"/users/{user.Username}")'>
                        <MudCardContent>
                            <div class="d-flex align-center gap-3">
                                <AvatarDisplay Username="@user.Username" AvatarId="@user.AvatarId" Size="48" />
                                <div>
                                    <MudLink Href="@($"/users/{user.Username}")" Typo="Typo.h6"
                                             Style="font-family:'Cinzel',serif; color:#e8e0f0;"
                                             @onclick:stopPropagation="true">@user.Username</MudLink>
                                    <MudText Typo="Typo.body2" Style="color:#948aa8;">@user.DeckCount public deck@(user.DeckCount == 1 ? "" : "s")</MudText>
                                </div>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}
else
{
    @if (_decks.Count == 0)
    {
        <MudText Style="color:#948aa8;">No decks found for "@Q".</MudText>
    }
    else
    {
        <MudGrid>
            @foreach (var deck in _decks)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Style="border:1px solid #352d47; cursor:pointer;" Class="deck-card"
                             @onclick='() => Nav.NavigateTo($"/decks/{deck.Id}")'>
                        <div style="height:120px;border-radius:4px 4px 0 0;@ColorIdentityHelper.BannerStyle(deck.ColorIdentity)"></div>
                        <MudCardContent>
                            <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif;">@deck.Name</MudText>
                            <div class="d-flex align-center gap-2 mt-1">
                                <FormatBadge Format="@deck.Format" />
                                <MudLink Href="@($"/users/{deck.OwnerUsername}")" Typo="Typo.caption" Style="color:#948aa8;"
                                         @onclick:stopPropagation="true">by @deck.OwnerUsername</MudLink>
                                <MudText Typo="Typo.caption" Style="color:#948aa8;">· @deck.CardCount cards</MudText>
                            </div>
                            @if (deck.Description != null)
                            {
                                <MudText Typo="Typo.body2" Class="mt-2" Style="color:#948aa8;">@deck.Description</MudText>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
}

@code {
    [SupplyParameterFromQuery] string? Q { get; set; }
    [SupplyParameterFromQuery] string? Type { get; set; }

    List<DeckSummary> _decks = [];
    List<UserSearchResult> _users = [];
    bool _loading = true;
    string _type = "name";

    string? _lastQ;
    string? _lastType;
    CancellationTokenSource? _cts;

    protected override async Task OnParametersSetAsync()
    {
        if (Q == _lastQ && Type == _lastType) return;
        _lastQ = Q;
        _lastType = Type;

        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        _type = Type ?? "name";
        _decks = [];
        _users = [];
        _loading = true;

        try
        {
            if (!string.IsNullOrWhiteSpace(Q))
            {
                if (_type == "user")
                    _users = await Api.SearchUsersAsync(Q);
                else
                    _decks = await Api.SearchDecksAsync(Q, _type);
            }
            if (!token.IsCancellationRequested)
                _loading = false;
        }
        catch (OperationCanceledException) { }
    }
}