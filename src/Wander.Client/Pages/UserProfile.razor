@page "/users/{Username}"
@inject WanderApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState
@using Microsoft.AspNetCore.Components.Authorization
@using Wander.Client.Models

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    return;
}

@if (_profile == null)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
        <MudText Typo="Typo.h5" Style="color:#948aa8;">User not found.</MudText>
    </MudContainer>
    return;
}

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 pa-6" Style="max-width:900px;">
    @if (_isSelf)
    {
        <MudAlert Severity="Severity.Info" Class="mb-6">
            This is how your profile appears to others.
            <MudLink Href="/settings" Color="Color.Primary" Class="ml-1">Edit your profile</MudLink>
        </MudAlert>
    }

    <!-- Centered profile header -->
    <div class="d-flex flex-column align-center mb-8" style="text-align:center;">
        <div class="mb-4">
            <AvatarDisplay Username="@_profile.Username" AvatarId="@_profile.AvatarId" Size="96" />
        </div>
        <p class="wander-label mb-1">Wanderer</p>
        <MudText Typo="Typo.h3" Style="color:#c4a35f;">@_profile.Username</MudText>
        @if (_profile.FirstName != null || _profile.LastName != null)
        {
            <MudText Typo="Typo.h6" Class="mt-1">
                @string.Join(" ", new[] { _profile.FirstName, _profile.LastName }.Where(s => s != null))
            </MudText>
        }
        @if (_profile.Pronouns != null)
        {
            <MudText Typo="Typo.caption" Style="color:#948aa8;">@_profile.Pronouns</MudText>
        }
        @if (_profile.Bio != null)
        {
            <MudText Typo="Typo.body2" Class="mt-3" Style="color:#948aa8; max-width:480px;">@_profile.Bio</MudText>
        }
        @if (_isAuthenticated && !_isSelf)
        {
            <div class="mt-4">
                <MudButton Variant="@(_isFollowing ? Variant.Outlined : Variant.Filled)"
                           Color="Color.Primary"
                           OnClick="ToggleFollow"
                           Disabled="_followBusy">
                    @(_isFollowing ? "Unfollow" : "Follow")
                </MudButton>
            </div>
        }
    </div>

    <!-- Stat strip -->
    <MudGrid Spacing="0" Class="mb-8"
             Style="border-top:1px solid #352d47;border-bottom:1px solid #352d47;">
        <MudItem xs="4" Style="padding:24px 16px;text-align:center;border-right:1px solid #352d47;">
            <div class="wander-display wander-tnum" style="font-size:28px;font-weight:400;color:#ebe4d0;">
                @_profile.PublicDecks.Count
            </div>
            <p class="wander-label mt-1">Decks</p>
        </MudItem>
        <MudItem xs="4" Style="padding:24px 16px;text-align:center;border-right:1px solid #352d47;">
            <div class="wander-display wander-tnum" style="font-size:28px;font-weight:400;color:#ebe4d0;">
                @(_profile.FollowerCount?.ToString() ?? "—")
            </div>
            <p class="wander-label mt-1">Followers</p>
        </MudItem>
        <MudItem xs="4" Style="padding:24px 16px;text-align:center;">
            <div class="wander-display wander-tnum" style="font-size:28px;font-weight:400;color:#ebe4d0;">
                @(_profile.FollowingCount?.ToString() ?? "—")
            </div>
            <p class="wander-label mt-1">Following</p>
        </MudItem>
    </MudGrid>

    <!-- Public decks -->
    <MudTabs Elevation="0" Rounded="false" Style="background:transparent;">

        <MudTabPanel Text="Decks" Class="pt-4">
            @if (_profile.PublicDecks.Count > 0)
            {
                <MudText Typo="Typo.h6" Class="mb-3" Style="font-family:'Cinzel',serif;">Public Decks</MudText>
                <MudGrid>
                    @foreach (var deck in _profile.PublicDecks)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudCard Style="border:1px solid #352d47; cursor:pointer;" Class="deck-card"
                                     @onclick='() => Nav.NavigateTo($"/decks/{deck.Id}")'>
                                <MudCardContent>
                                    <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif;">@deck.Name</MudText>
                                    <div class="d-flex align-center gap-2 mt-1">
                                        <MudText Typo="Typo.caption" Style="color:#948aa8;">@deck.Format</MudText>
                                        <MudText Typo="Typo.caption" Style="color:#948aa8;">· @deck.CardCount cards</MudText>
                                    </div>
                                    @if (deck.Description != null)
                                    {
                                        <MudText Typo="Typo.body2" Class="mt-2" Style="color:#948aa8;">@deck.Description</MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
            else
            {
                <MudText Style="color:#948aa8;">No public decks.</MudText>
            }
        </MudTabPanel>

        @if (_profile.ActivityPrivacy == Privacy.Public ||
                       (_profile.ActivityPrivacy == Privacy.Restricted && _isFollowing))
        {
        <MudTabPanel Text="Activity" Class="pt-4" OnClick="LoadActivity">
            @if (_activityLoading)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }
            else if (_activity is null || _activity.Items.Count == 0)
            {
                <MudText Style="color:#948aa8;">No public activity.</MudText>
            }
            else
            {
                @foreach (var item in _activity.Items)
                {
                    <div class="d-flex align-center gap-2 mb-3">
                        <MudIcon Icon="@ActivityIcon(item.Type)"
                                 Size="Size.Small" Style="color:#948aa8;" />
                        <MudText Typo="Typo.body2">
                            @ActivitySentence(item)
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color:#948aa8; margin-left:auto;">
                            @item.CreatedAt.ToString("MMM d")
                        </MudText>
                    </div>
                }
                @if (_activity.Total > _activity.Items.Count)
                {
                    <MudButton Variant="Variant.Text" OnClick="LoadMoreActivity"
                               Style="color:#948aa8;">
                        Load more
                    </MudButton>
                }
            }
        </MudTabPanel>
        }
    </MudTabs>
</MudContainer>

@code {
    [Parameter] public string Username { get; set; } = "";

    PublicProfileResponse? _profile;
    bool _loading = true, _isSelf, _isAuthenticated, _isFollowing, _followBusy, _activityLoading;
    ActivityPageResponse? _activity;
    int _activityPage = 1;

    protected override async Task OnInitializedAsync()
    {
        _profile = await Api.GetUserProfileAsync(Username);
        if (_profile != null)
        {
            var authState = await AuthState.GetAuthenticationStateAsync();
            var identity = authState.User.Identity;
            _isAuthenticated = identity?.IsAuthenticated == true;
            _isSelf = _isAuthenticated &&
                      string.Equals(identity!.Name, Username, StringComparison.OrdinalIgnoreCase);
            _isFollowing = _profile.IsFollowing;
        }
        _loading = false;
    }

    async Task ToggleFollow()
    {
        _followBusy = true;
        var wasFollowing = _isFollowing;
        var response = wasFollowing
            ? await Api.UnfollowUserAsync(_profile!.Username)
            : await Api.FollowUserAsync(_profile!.Username);

        if (response.IsSuccessStatusCode)
        {
            _isFollowing = !wasFollowing;
            // Optimistic count update — only if FollowerCount is visible (not hidden by privacy)
            if (_profile!.FollowerCount != null)
                _profile = _profile with { FollowerCount = _profile.FollowerCount + (wasFollowing ? -1 : 1) };
        }
        else
        {
            Snackbar.Add(wasFollowing ? "Failed to unfollow." : "Failed to follow.", Severity.Error);
        }
        _followBusy = false;
    }

    async Task LoadActivity()
    {
        if (_activity is not null) return;  // already loaded
        _activityLoading = true;
        _activity = await Api.GetUserActivityAsync(_profile!.Username);
        _activityLoading = false;
    }

    async Task LoadMoreActivity()
    {
        _activityPage++;
        var more = await Api.GetUserActivityAsync(_profile!.Username, _activityPage);
        if (more is not null)
            _activity = new ActivityPageResponse(
                [.. _activity!.Items, .. more.Items], more.Total);
    }

    static string ActivityIcon(string type) => type switch
    {
        "LikedDeck" => Icons.Material.Filled.Favorite,
        "CommentedOnDeck" => Icons.Material.Filled.Comment,
        "FollowedUser" => Icons.Material.Filled.PersonAdd,
        "MadeDeckPublic" => Icons.Material.Filled.Public,
        _ => Icons.Material.Filled.Circle
    };

    MarkupString ActivitySentence(ActivityItem item)
    {
        var name = System.Net.WebUtility.HtmlEncode(item.TargetName ?? "unknown");
        string html = item.Type switch
        {
            "LikedDeck" => $"Liked <a href=\"/decks/{item.TargetId}\" style=\"color:#c4a35f;\">{name}</a>",
            "CommentedOnDeck" => $"Commented on <a href=\"/decks/{item.TargetId}\" style=\"color:#c4a35f;\">{name}</a>",
            "FollowedUser" => $"Followed <a href=\"/users/{item.TargetId}\" style=\"color:#c4a35f;\">{name}</a>",
            "MadeDeckPublic" => $"Made <a href=\"/decks/{item.TargetId}\" style=\"color:#c4a35f;\">{name}</a> public",
            _ => name
        };
        return new MarkupString(html);
    }
}