@page "/decks"
@attribute [Authorize]
@inject WanderApiClient Api
@inject NavigationManager Nav
@inject IDialogService Dialogs
@inject AuthenticationStateProvider AuthStateProvider

<MudText Typo="Typo.h4" Class="page-title">Your Collection</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="CreateDeck" Class="mb-4">
    New Deck
</MudButton>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_decks.Count == 0)
{
    <MudText Typo="Typo.body1" Style="color:#948aa8;">
        Your grimoire is empty. Create your first deck.
    </MudText>
}
else
{
    <MudGrid>
        @foreach (var deck in _decks)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Style="border:1px solid #352d47; cursor:pointer;"
                         @onclick='() => Nav.NavigateTo($"/decks/{deck.Id}")'>
                    <div style="height:120px;border-radius:4px 4px 0 0;@ColorIdentityHelper.BannerStyle(deck.ColorIdentity)"></div>
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Style="font-family:'Cinzel',serif;">@deck.Name</MudText>
                        <div class="d-flex align-center gap-2 mt-1">
                            <FormatBadge Format="@deck.Format" />
                            <MudText Typo="Typo.caption" Style="color:#948aa8;">@deck.CardCount cards</MudText>
                        </div>
                        @if (deck.Description != null)
                        {
                            <MudText Typo="Typo.body2" Class="mt-2" Style="color:#948aa8;">
                                @deck.Description
                            </MudText>
                        }
                    </MudCardContent>
                    <div @onclick:stopPropagation="true">
                        <MudCardActions>
                            <MudButton Size="Size.Small"
                                       OnClick='() => Nav.NavigateTo($"/decks/{deck.Id}")'>
                                Edit
                            </MudButton>
                            <MudButton Size="Size.Small" Color="Color.Error"
                                       OnClick="() => DeleteDeck(deck)">
                                Delete
                            </MudButton>
                        </MudCardActions>
                    </div>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    List<DeckSummary> _decks = [];
    bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (auth.User.IsInRole("Admin"))
        {
            Nav.NavigateTo("/admin", replace: true);
            return;
        }
        _decks = await Api.GetMyDecksAsync();
        _loading = false;
    }

    async Task CreateDeck()
    {
        var dialog = await Dialogs.ShowAsync<Dialogs.CreateDeckDialog>("New Deck");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is DeckSummary created)
            Nav.NavigateTo($"/decks/{created.Id}");
    }

    async Task DeleteDeck(DeckSummary deck)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Message, $"Delete \"{deck.Name}\"? This cannot be undone." },
            { x => x.YesText, "Delete" },
            { x => x.CancelText, "Cancel" }
        };
        var dialog = await Dialogs.ShowAsync<MudMessageBox>("Delete Deck", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await Api.DeleteDeckAsync(deck.Id);
            _decks.Remove(deck);
        }
    }
}