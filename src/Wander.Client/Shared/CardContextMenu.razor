<MudMenu PositionAtCursor="true" Dense="true" PopoverClass="wander-context-menu">
    <ActivatorContent Context="menuCtx">
        <div @oncontextmenu="e => menuCtx.OpenAsync(e)"
             @oncontextmenu:preventDefault="true"
             @oncontextmenu:stopPropagation="true"
             class="card-row-activator">
            @ChildContent
        </div>
    </ActivatorContent>
    <ChildContent>
        @if (Context == CardContext.BuilderMain)
        {
            @if (!Card!.IsCommander &&
                 Card.TypeLine.Contains("Legendary", StringComparison.OrdinalIgnoreCase))
            {
                <MudMenuItem OnClick="() => OnSetCommander.InvokeAsync(Card)">
                    <div class="wander-ctx-item">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color:#c9a84c;" />
                        Set as Commander
                    </div>
                </MudMenuItem>
            }
            @if (Card!.IsSideboard)
            {
                <MudMenuItem OnClick="() => OnMoveToMain.InvokeAsync(Card)">
                    <div class="wander-ctx-item">
                        <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                        Move to Main Deck
                    </div>
                </MudMenuItem>
            }
            else
            {
                <MudMenuItem OnClick="() => OnMoveToSideboard.InvokeAsync(Card)">
                    <div class="wander-ctx-item">
                        <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                        Move to Sideboard
                    </div>
                </MudMenuItem>
            }
            <MudMenuItem OnClick="() => OnRemove.InvokeAsync(Card)">
                <div class="wander-ctx-item wander-ctx-item-danger">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                    Remove from Deck
                </div>
            </MudMenuItem>
        }
        else if (Context == CardContext.BuilderCommander)
        {
            <MudMenuItem OnClick="() => OnRemove.InvokeAsync(Card)">
                <div class="wander-ctx-item wander-ctx-item-danger">
                    <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
                    Remove from Deck
                </div>
            </MudMenuItem>
        }
        else if (Context == CardContext.BuilderSearch)
        {
            <MudMenuItem OnClick="() => OnAddToDeck.InvokeAsync()">
                <div class="wander-ctx-item">
                    <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" />
                    Add to Deck
                </div>
            </MudMenuItem>
            <MudMenuItem OnClick="() => OnAddToSideboard.InvokeAsync()">
                <div class="wander-ctx-item">
                    <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" />
                    Add to Sideboard
                </div>
            </MudMenuItem>
            @if (SearchCard!.TypeLine.Contains("Legendary", StringComparison.OrdinalIgnoreCase))
            {
                <MudMenuItem OnClick="() => OnAddAsCommander.InvokeAsync()">
                    <div class="wander-ctx-item">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color:#c9a84c;" />
                        Add as Commander
                    </div>
                </MudMenuItem>
            }
        }
        else if (Context == CardContext.Viewer)
        {
            <MudMenuItem Href="@($"https://scryfall.com/search?q=!\"{Uri.EscapeDataString(Card!.CardName)}\"")"
                         Target="_blank"
                         Icon="@Icons.Material.Filled.OpenInNew">
                Open on Scryfall
            </MudMenuItem>
        }
    </ChildContent>
</MudMenu>

@code {
    [Parameter] public CardContext Context { get; set; }
    [Parameter] public DeckCardDetail? Card { get; set; }
    [Parameter] public CardSearchResult? SearchCard { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<DeckCardDetail> OnSetCommander { get; set; }
    [Parameter] public EventCallback<DeckCardDetail> OnMoveToSideboard { get; set; }
    [Parameter] public EventCallback<DeckCardDetail> OnMoveToMain { get; set; }
    [Parameter] public EventCallback<DeckCardDetail> OnRemove { get; set; }
    [Parameter] public EventCallback OnAddToDeck { get; set; }
    [Parameter] public EventCallback OnAddToSideboard { get; set; }
    [Parameter] public EventCallback OnAddAsCommander { get; set; }
    [Parameter] public EventCallback OnOpenScryfall { get; set; }
}
