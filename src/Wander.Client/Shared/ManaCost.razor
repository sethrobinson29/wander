@foreach (var sym in ParseSymbols(Cost))
{
    <span class="mana-pip mana-@sym">@sym</span>
}

@code {
    [Parameter] public string? Cost { get; set; }

    static IEnumerable<string> ParseSymbols(string? cost)
    {
        if (string.IsNullOrEmpty(cost)) yield break;
        foreach (System.Text.RegularExpressions.Match m in
            System.Text.RegularExpressions.Regex.Matches(cost, @"\{([^}]+)\}"))
            yield return m.Groups[1].Value;
    }
}